@page "/activity"
@page "/activity/mine"
@attribute [Authorize(Roles = "User")]
@implements IDisposable
@using JIM.Models.Activities
@using JIM.Models.Enums
@using JIM.Models.Staging
@using JIM.Models.Utility;
@using JIM.Utilities;
@using JIM.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IJimApplicationFactory JimFactory
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IUserPreferenceService PreferenceService

@* Copyright (c) Tetron Limited. All rights reserved. *@
@* Licensed under the Tetron Commercial License. See LICENSE file in the project root. *@

<PageTitle>@_pageTitle</PageTitle>
<MudText Typo="Typo.h4"><MudIcon Icon="@Icons.Material.Filled.ReceiptLong" Size="Size.Large" Class="mr-2 mb-1" Style="vertical-align: middle;" />@_pageTitle</MudText>
<MudBreadcrumbs Items="_breadcrumbs" Class="ps-0"></MudBreadcrumbs>

<MudText Typo="Typo.subtitle1" Class="mud-text-secondary mt-2 mb-0">
    @_pageDescription
</MudText>

@if (_preferencesLoaded)
{
@* ─── Category quick-filter ─── *@
<MudStack Row="true" Spacing="2" Class="mt-4 flex-wrap" AlignItems="AlignItems.Center">
    <MudText Typo="Typo.button" Class="mud-text-secondary">Category:</MudText>
    <MudChip T="string" OnClick="() => OnCategorySelectedAsync(null)"
             Variant="@(IsAllCategorySelected ? Variant.Filled : Variant.Outlined)"
             Color="@(IsAllCategorySelected ? Color.Primary : Color.Default)">All</MudChip>
    @foreach (var chipCategory in Enum.GetValues<ActivityTargetCategory>())
    {
        <MudChip T="string" OnClick="() => OnCategorySelectedAsync(chipCategory)"
                 Variant="@(_selectedCategory == chipCategory ? Variant.Filled : Variant.Outlined)"
                 Color="@(_selectedCategory == chipCategory ? Color.Primary : Color.Default)">@GetCategoryLabel(chipCategory)</MudChip>
    }
</MudStack>

<MudStack Row="true" Spacing="3" Class="mt-3 flex-wrap" AlignItems="AlignItems.End">
    <MudItem Class="flex-grow-1">
        <MudSelect T="ActivityTargetOperationType" Label="Operation" Variant="Variant.Outlined"
                   Dense="true" Clearable="true" MultiSelection="true"
                   SelectedValues="_filterOperations"
                   SelectedValuesChanged="OnOperationFilterChanged"
                   MultiSelectionTextFunc="@(new Func<IReadOnlyList<string>, string>(GetMultiSelectText))">
            <MudSelectItem T="ActivityTargetOperationType" Value="ActivityTargetOperationType.Create">Create</MudSelectItem>
            <MudSelectItem T="ActivityTargetOperationType" Value="ActivityTargetOperationType.Read">Read</MudSelectItem>
            <MudSelectItem T="ActivityTargetOperationType" Value="ActivityTargetOperationType.Update">Update</MudSelectItem>
            <MudSelectItem T="ActivityTargetOperationType" Value="ActivityTargetOperationType.Delete">Delete</MudSelectItem>
            <MudSelectItem T="ActivityTargetOperationType" Value="ActivityTargetOperationType.Clear">Clear</MudSelectItem>
            <MudSelectItem T="ActivityTargetOperationType" Value="ActivityTargetOperationType.Execute">Execute</MudSelectItem>
            <MudSelectItem T="ActivityTargetOperationType" Value="ActivityTargetOperationType.ImportHierarchy">Import Hierarchy</MudSelectItem>
            <MudSelectItem T="ActivityTargetOperationType" Value="ActivityTargetOperationType.ImportSchema">Import Schema</MudSelectItem>
            <MudSelectItem T="ActivityTargetOperationType" Value="ActivityTargetOperationType.Revert">Revert</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem Class="flex-grow-1">
        <MudSelect T="ActivityOutcomeType" Label="Outcomes" Variant="Variant.Outlined"
                   Dense="true" Clearable="true" MultiSelection="true"
                   SelectedValues="_filterOutcomes"
                   SelectedValuesChanged="OnOutcomeFilterChanged"
                   MultiSelectionTextFunc="@(new Func<IReadOnlyList<string>, string>(GetMultiSelectText))">
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.Added">Added</MudSelectItem>
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.Updated">Updated</MudSelectItem>
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.Deleted">Deleted</MudSelectItem>
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.Projected">Projected</MudSelectItem>
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.Joined">Joined</MudSelectItem>
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.AttributeFlows">Attribute Flows</MudSelectItem>
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.Disconnected">Disconnected</MudSelectItem>
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.DriftCorrections">Drift Corrections</MudSelectItem>
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.Provisioned">Provisioned</MudSelectItem>
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.Exported">Exported</MudSelectItem>
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.Deprovisioned">Deprovisioned</MudSelectItem>
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.Created">Created</MudSelectItem>
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.PendingExports">Pending Exports</MudSelectItem>
            <MudSelectItem T="ActivityOutcomeType" Value="ActivityOutcomeType.Errors">Errors</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem Class="flex-grow-1">
        <MudSelect T="ActivityTargetType" Label="Type" Variant="Variant.Outlined"
                   Dense="true" Clearable="true" MultiSelection="true"
                   SelectedValues="_filterTypes"
                   SelectedValuesChanged="OnTypeFilterChanged"
                   MultiSelectionTextFunc="@(new Func<IReadOnlyList<string>, string>(GetMultiSelectText))">
            <MudSelectItem T="ActivityTargetType" Value="ActivityTargetType.ConnectedSystem">Connected System</MudSelectItem>
            <MudSelectItem T="ActivityTargetType" Value="ActivityTargetType.ConnectedSystemRunProfile">Connected System Run Profile</MudSelectItem>
            <MudSelectItem T="ActivityTargetType" Value="ActivityTargetType.SyncRule">Synchronisation Rule</MudSelectItem>
            <MudSelectItem T="ActivityTargetType" Value="ActivityTargetType.MetaverseObject">Metaverse Object</MudSelectItem>
            <MudSelectItem T="ActivityTargetType" Value="ActivityTargetType.MetaverseAttribute">Metaverse Attribute</MudSelectItem>
            <MudSelectItem T="ActivityTargetType" Value="ActivityTargetType.ExampleDataTemplate">Data Generation Template</MudSelectItem>
            <MudSelectItem T="ActivityTargetType" Value="ActivityTargetType.TrustedCertificate">Trusted Certificate</MudSelectItem>
            <MudSelectItem T="ActivityTargetType" Value="ActivityTargetType.ObjectMatchingRule">Object Matching Rule</MudSelectItem>
            <MudSelectItem T="ActivityTargetType" Value="ActivityTargetType.ServiceSetting">Service Setting</MudSelectItem>
            <MudSelectItem T="ActivityTargetType" Value="ActivityTargetType.HistoryRetentionCleanup">History Retention Cleanup</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem Class="flex-grow-1">
        <MudSelect T="ActivityStatus" Label="Status" Variant="Variant.Outlined"
                   Dense="true" Clearable="true" MultiSelection="true"
                   SelectedValues="_filterStatuses"
                   SelectedValuesChanged="OnStatusFilterChanged"
                   MultiSelectionTextFunc="@(new Func<IReadOnlyList<string>, string>(GetMultiSelectText))">
            <MudSelectItem T="ActivityStatus" Value="ActivityStatus.InProgress">In Progress</MudSelectItem>
            <MudSelectItem T="ActivityStatus" Value="ActivityStatus.Complete">Complete</MudSelectItem>
            <MudSelectItem T="ActivityStatus" Value="ActivityStatus.CompleteWithWarning">Complete With Warning</MudSelectItem>
            <MudSelectItem T="ActivityStatus" Value="ActivityStatus.CompleteWithError">Complete With Error</MudSelectItem>
            <MudSelectItem T="ActivityStatus" Value="ActivityStatus.FailedWithError">Failed With Error</MudSelectItem>
            <MudSelectItem T="ActivityStatus" Value="ActivityStatus.Cancelled">Cancelled</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem Class="flex-grow-1">
        <MudSelect T="ActivityInitiatorType" Label="Initiator" Variant="Variant.Outlined"
                   Dense="true" Clearable="true" MultiSelection="true"
                   SelectedValues="_filterInitiatorTypes"
                   SelectedValuesChanged="OnInitiatorTypeFilterChanged"
                   MultiSelectionTextFunc="@(new Func<IReadOnlyList<string>, string>(GetMultiSelectText))">
            <MudSelectItem T="ActivityInitiatorType" Value="ActivityInitiatorType.User">User</MudSelectItem>
            <MudSelectItem T="ActivityInitiatorType" Value="ActivityInitiatorType.ApiKey">API Key</MudSelectItem>
            <MudSelectItem T="ActivityInitiatorType" Value="ActivityInitiatorType.System">System</MudSelectItem>
        </MudSelect>
    </MudItem>
    <MudItem Class="flex-grow-1">
        @* No dense margin: matches the height of the neighbouring filter selects. *@
        <MudDateRangePicker Label="Created between" Variant="Variant.Outlined"
                            DateRange="_filterDateRange" DateRangeChanged="OnDateRangeChanged"
                            Clearable="true" AutoClose="true" />
    </MudItem>
    <MudItem Class="d-flex align-end">
        <MudCheckBox T="bool" Value="_filterHasChildren" ValueChanged="OnHasChildrenFilterChanged"
                     Label="Has child activities" Dense="true" Class="mb-1 mud-typography-nowrap" />
    </MudItem>
    <MudItem Class="d-flex align-end mb-2">
        <MudTooltip Text="@(_pollingPaused ? "Resume auto-refresh" : "Pause auto-refresh")" Placement="Placement.Top">
            <MudIconButton Icon="@(_pollingPaused ? Icons.Material.Filled.PlayArrow : Icons.Material.Filled.Pause)"
                           Size="Size.Small"
                           OnClick="@(() => _pollingPaused = !_pollingPaused)"
                           Color="@(_pollingPaused ? Color.Warning : Color.Default)" />
        </MudTooltip>
    </MudItem>
</MudStack>

<MudTable @ref="_table" T="Activity" ServerData="ServerReload" @bind-CurrentPage="_currentPage" RowsPerPage="@_rowsPerPage" RowsPerPageChanged="OnRowsPerPageChanged" Hover="true" Dense="true" Breakpoint="Breakpoint.Sm"
    Class="mt-5" Outlined="true" Elevation="0" OnRowClick="HandleRowClick" RowClass="cursor-pointer" Loading="@_loading"
    LoadingProgressColor="Color.Primary">
    <ToolBarContent>
        <MudSpacer />
        <MudTextField T="string" Value="@_searchString" ValueChanged="@(s => OnSearch(s))" Variant="Variant.Outlined" Placeholder="Search target or initiator" Margin="Margin.Dense"
            Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
            Class="mt-0" />
    </ToolBarContent>
    <HeaderContent>
        <MudTh>
            <MudTableSortLabel SortLabel="operation" T="Activity">
                <MudText Typo="Typo.button">Operation</MudText>
            </MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortLabel="target" T="Activity">
                <MudText Typo="Typo.button">Target</MudText>
            </MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudText Typo="Typo.button">Outcomes</MudText>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortLabel="type" T="Activity">
                <MudText Typo="Typo.button">Type</MudText>
            </MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortLabel="initiatedby" T="Activity">
                <MudText Typo="Typo.button">Initiated By</MudText>
            </MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortLabel="status" T="Activity">
                <MudText Typo="Typo.button">Status</MudText>
            </MudTableSortLabel>
        </MudTh>
        <MudTh>
            <MudTableSortLabel SortLabel="created" T="Activity" InitialDirection="SortDirection.Descending">
                <MudText Typo="Typo.button">Created</MudText>
            </MudTableSortLabel>
        </MudTh>
        <MudTh></MudTh>
    </HeaderContent>
    <RowTemplate Context="context">
        <MudTd DataLabel="Operation">
            <MudChip T="string" Variant="Variant.Text"
                Color="Helpers.GetActivityMudBlazorColorForOperation(context.TargetOperationType)">
                @context.TargetOperationType.ToString().SplitOnCapitalLetters()
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Target">
            @if (!string.IsNullOrEmpty(context.TargetContext) && !string.IsNullOrEmpty(context.TargetName))
            {
                <span><strong>@context.TargetContext</strong> → @context.TargetName</span>
            }
            else if (!string.IsNullOrEmpty(context.TargetContext))
            {
                <span><strong>@context.TargetContext</strong></span>
            }
            else if (!string.IsNullOrEmpty(context.TargetName))
            {
                @context.TargetName
            }
            else
            {
                <EmptyValue />
            }
        </MudTd>
        <MudTd DataLabel="Outcomes">
            @if (context.TargetType == ActivityTargetType.ConnectedSystemRunProfile
                 && context.TargetOperationType == ActivityTargetOperationType.Execute
                 && context.Status != ActivityStatus.InProgress)
            {
                @* Run Profile execution stats - run-type-aware display *@
                @if (HasAnyStats(context))
                {
                    var effectiveRunType = GetEffectiveRunType(context.ConnectedSystemRunType, context.TargetName);
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        @if (effectiveRunType == "Import")
                        {
                            @if (context.TotalAdded > 0)
                            {
                                <MudTooltip Text="CSOs Added" Arrow="true" Placement="Placement.Top">
                                    <MudChip T="string" Color="Color.Success" Variant="Variant.Text"
                                             Icon="@Helpers.GetOperationIcon(ObjectChangeType.Added)" Class="jim-stat-chip">
                                        @context.TotalAdded.ToString("N0")
                                    </MudChip>
                                </MudTooltip>
                            }
                            @if (context.TotalUpdated > 0)
                            {
                                <MudTooltip Text="CSOs Updated" Arrow="true" Placement="Placement.Top">
                                    <MudChip T="string" Color="Color.Info" Variant="Variant.Text"
                                             Icon="@Helpers.GetOperationIcon(ObjectChangeType.Updated)" Class="jim-stat-chip">
                                        @context.TotalUpdated.ToString("N0")
                                    </MudChip>
                                </MudTooltip>
                            }
                            @if (context.TotalDeleted > 0)
                            {
                                <MudTooltip Text="CSO Deletions Detected" Arrow="true" Placement="Placement.Top">
                                    <MudChip T="string" Color="Color.Error" Variant="Variant.Text"
                                             Icon="@Helpers.GetOperationIcon(ObjectChangeType.Deleted)" Class="jim-stat-chip">
                                        @context.TotalDeleted.ToString("N0")
                                    </MudChip>
                                </MudTooltip>
                            }
                        }
                        else if (effectiveRunType == "Sync")
                        {
                            @if (context.TotalProjected > 0)
                            {
                                <MudTooltip Text="MVOs Projected" Arrow="true" Placement="Placement.Top">
                                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Text"
                                             Icon="@Helpers.GetOperationIcon(ObjectChangeType.Projected)" Class="jim-stat-chip">
                                        @context.TotalProjected.ToString("N0")
                                    </MudChip>
                                </MudTooltip>
                            }
                            @if (context.TotalJoined > 0)
                            {
                                <MudTooltip Text="CSOs Joined" Arrow="true" Placement="Placement.Top">
                                    <MudChip T="string" Color="Color.Secondary" Variant="Variant.Text"
                                             Icon="@Helpers.GetOperationIcon(ObjectChangeType.Joined)" Class="jim-stat-chip">
                                        @context.TotalJoined.ToString("N0")
                                    </MudChip>
                                </MudTooltip>
                            }
                            @if (context.TotalAttributeFlows > 0)
                            {
                                <MudTooltip Text="MVOs with Attribute Flow" Arrow="true" Placement="Placement.Top">
                                    <MudChip T="string" Color="Color.Info" Variant="Variant.Text"
                                             Icon="@Helpers.GetOperationIcon(ObjectChangeType.AttributeFlow)" Class="jim-stat-chip">
                                        @context.TotalAttributeFlows.ToString("N0")
                                    </MudChip>
                                </MudTooltip>
                            }
                            @if (context.TotalDisconnected > 0)
                            {
                                <MudTooltip Text="CSOs Disconnected" Arrow="true" Placement="Placement.Top">
                                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Text"
                                             Icon="@Helpers.GetOperationIcon(ObjectChangeType.Disconnected)" Class="jim-stat-chip">
                                        @context.TotalDisconnected.ToString("N0")
                                    </MudChip>
                                </MudTooltip>
                            }
                            @if (context.TotalDeleted > 0)
                            {
                                <MudTooltip Text="CSOs Deleted" Arrow="true" Placement="Placement.Top">
                                    <MudChip T="string" Color="Color.Error" Variant="Variant.Text"
                                             Icon="@Helpers.GetOperationIcon(ObjectChangeType.Deleted)" Class="jim-stat-chip">
                                        @context.TotalDeleted.ToString("N0")
                                    </MudChip>
                                </MudTooltip>
                            }
                            @if (context.TotalDriftCorrections > 0)
                            {
                                <MudTooltip Text="CSOs Drift Corrected" Arrow="true" Placement="Placement.Top">
                                    <MudChip T="string" Color="Color.Warning" Variant="Variant.Text"
                                             Icon="@Helpers.GetOperationIcon(ObjectChangeType.DriftCorrection)" Class="jim-stat-chip">
                                        @context.TotalDriftCorrections.ToString("N0")
                                    </MudChip>
                                </MudTooltip>
                            }
                            @if (context.TotalProvisioned > 0)
                            {
                                <MudTooltip Text="CSOs Provisioned" Arrow="true" Placement="Placement.Top">
                                    <MudChip T="string" Color="Color.Primary" Variant="Variant.Text"
                                             Icon="@Helpers.GetOutcomeTypeIcon(ActivityRunProfileExecutionItemSyncOutcomeType.Provisioned)" Class="jim-stat-chip">
                                        @context.TotalProvisioned.ToString("N0")
                                    </MudChip>
                                </MudTooltip>
                            }
                            @if (context.TotalPendingExports > 0)
                            {
                                <MudTooltip Text="CSO Pending Exports" Arrow="true" Placement="Placement.Top">
                                    <MudChip T="string" Color="Color.Info" Variant="Variant.Text"
                                             Icon="@Helpers.GetOperationIcon(ObjectChangeType.PendingExport)" Class="jim-stat-chip">
                                        @context.TotalPendingExports.ToString("N0")
                                    </MudChip>
                                </MudTooltip>
                            }
                        }
                        else if (effectiveRunType == "Export")
                        {
                            @if (context.TotalExported > 0)
                            {
                                <MudTooltip Text="CSOs Exported" Arrow="true" Placement="Placement.Top">
                                    <MudChip T="string" Color="Color.Info" Variant="Variant.Text"
                                             Icon="@Helpers.GetOperationIcon(ObjectChangeType.Exported)" Class="jim-stat-chip">
                                        @context.TotalExported.ToString("N0")
                                    </MudChip>
                                </MudTooltip>
                            }
                            @if (context.TotalDeprovisioned > 0)
                            {
                                <MudTooltip Text="CSOs Deprovisioned" Arrow="true" Placement="Placement.Top">
                                    <MudChip T="string" Color="Color.Error" Variant="Variant.Text"
                                             Icon="@Helpers.GetOperationIcon(ObjectChangeType.Deprovisioned)" Class="jim-stat-chip">
                                        @context.TotalDeprovisioned.ToString("N0")
                                    </MudChip>
                                </MudTooltip>
                            }
                        }
                        @* Errors shown for all run types *@
                        @if (context.TotalErrors > 0)
                        {
                            <MudTooltip Text="Errors" Arrow="true" Placement="Placement.Top">
                                <MudChip T="string" Color="Color.Error" Variant="Variant.Filled"
                                         Icon="@Icons.Material.Filled.Error" Class="jim-stat-chip">
                                    @context.TotalErrors.ToString("N0")
                                </MudChip>
                            </MudTooltip>
                        }
                    </MudStack>
                }
                else
                {
                    @* Run Profile execution completed with no changes *@
                    <MudTooltip Text="No changes" Arrow="true" Placement="Placement.Top">
                        <MudChip T="string" Color="Color.Default" Variant="Variant.Text"
                                 Icon="@Icons.Material.Outlined.CheckCircle" Class="jim-stat-chip">
                            0
                        </MudChip>
                    </MudTooltip>
                }
            }
            else if (context.TargetType == ActivityTargetType.ExampleDataTemplate
                     && context.TargetOperationType == ActivityTargetOperationType.Execute
                     && context.Status != ActivityStatus.InProgress)
            {
                @* Data generation stats - only shows creates *@
                <MudTooltip Text="Objects Generated" Arrow="true" Placement="Placement.Top">
                    <MudChip T="string" Color="Color.Success" Variant="Variant.Text"
                             Icon="@Icons.Material.Filled.Add" Class="jim-stat-chip">
                        @context.TotalCreated.ToString("N0")
                    </MudChip>
                </MudTooltip>
            }
            else if (context.TargetType == ActivityTargetType.HistoryRetentionCleanup
                     && context.Status != ActivityStatus.InProgress)
            {
                @* History retention cleanup stats *@
                var totalDeleted = (context.DeletedCsoChangeCount ?? 0) + (context.DeletedMvoChangeCount ?? 0) + (context.DeletedActivityCount ?? 0);
                @if (totalDeleted > 0)
                {
                    <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center">
                        @if (context.DeletedCsoChangeCount > 0)
                        {
                            <MudTooltip Text="CSO Changes Deleted" Arrow="true" Placement="Placement.Top">
                                <MudChip T="string" Color="Color.Warning" Variant="Variant.Text"
                                         Icon="@Icons.Material.Filled.DeleteSweep" Class="jim-stat-chip">
                                    @context.DeletedCsoChangeCount.Value.ToString("N0")
                                </MudChip>
                            </MudTooltip>
                        }
                        @if (context.DeletedMvoChangeCount > 0)
                        {
                            <MudTooltip Text="MVO Changes Deleted" Arrow="true" Placement="Placement.Top">
                                <MudChip T="string" Color="Color.Warning" Variant="Variant.Text"
                                         Icon="@Icons.Material.Filled.DeleteSweep" Class="jim-stat-chip">
                                    @context.DeletedMvoChangeCount.Value.ToString("N0")
                                </MudChip>
                            </MudTooltip>
                        }
                        @if (context.DeletedActivityCount > 0)
                        {
                            <MudTooltip Text="Activities Deleted" Arrow="true" Placement="Placement.Top">
                                <MudChip T="string" Color="Color.Warning" Variant="Variant.Text"
                                         Icon="@Icons.Material.Filled.CleaningServices" Class="jim-stat-chip">
                                    @context.DeletedActivityCount.Value.ToString("N0")
                                </MudChip>
                            </MudTooltip>
                        }
                    </MudStack>
                }
                else
                {
                    <MudTooltip Text="No records to clean up" Arrow="true" Placement="Placement.Top">
                        <MudChip T="string" Color="Color.Default" Variant="Variant.Text"
                                 Icon="@Icons.Material.Outlined.CheckCircle" Class="jim-stat-chip">
                            0
                        </MudChip>
                    </MudTooltip>
                }
            }
            else
            {
                @* Stats not applicable for this activity type *@
                <EmptyValue />
            }
        </MudTd>
        <MudTd DataLabel="Type">@context.TargetType.ToString().SplitOnCapitalLetters()</MudTd>
        <MudTd DataLabel="Initiated By">
            @{
                if (context.InitiatedByType == ActivityInitiatorType.User)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Person" Class="mr-1" Style="vertical-align: middle;" />
                    <span>@context.InitiatedByName</span>
                }
                else if (context.InitiatedByType == ActivityInitiatorType.ApiKey)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Key" Class="mr-1" Style="vertical-align: middle;" />
                    <span>@context.InitiatedByName</span>
                }
                else if (context.InitiatedByType == ActivityInitiatorType.System)
                {
                    <MudIcon Icon="@Icons.Material.Filled.Schedule" Class="mr-1" Style="vertical-align: middle;" />
                    <span>@(context.InitiatedByName ?? "System")</span>
                }
                else if (!string.IsNullOrEmpty(context.InitiatedByName))
                {
                    <span>@context.InitiatedByName</span>
                }
            }
        </MudTd>
        <MudTd DataLabel="Status">
            <MudChip T="string" Variant="Variant.Text"
                Color="Helpers.GetActivityMudBlazorColorForStatus(context.Status)">
                @context.Status.ToString().SplitOnCapitalLetters()
            </MudChip>
        </MudTd>
        <MudTd DataLabel="Created">
            <MudTooltip Text="@context.Created.ToLocalTime().ToFriendlyDate()" Arrow="true" Placement="Placement.Top">
                @context.Created.ToLocalTime().ToRelativeTime()
            </MudTooltip>
        </MudTd>
        <MudTd>
            @if (_childActivityCounts.TryGetValue(context.Id, out var childCount) && childCount > 0)
            {
                <MudTooltip Text="@($"{childCount} child {(childCount == 1 ? "activity" : "activities")}")" Arrow="true" Placement="Placement.Top">
                    <MudChip T="string" Variant="Variant.Text" Color="Color.Default" Icon="@Icons.Material.Filled.AccountTree" Class="jim-stat-chip">@childCount</MudChip>
                </MudTooltip>
            }
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        There is no activity to show yet.
    </NoRecordsContent>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>
}

@code {
    private MudTable<Activity>? _table;
    private string _searchString = "";
    private bool _loading;
    private bool _isMyActivity;
    private Dictionary<Guid, int> _childActivityCounts = new();
    private Guid? _currentUserId;
    private string _pageTitle = "Activity";
    private string _pageDescription = "Monitor all activity across the system. View operations initiated by users or automated processes, including synchronisations, configuration changes, and system events.";
    private List<BreadcrumbItem> _breadcrumbs = new();
    private string _currentPath = "";
    private int _currentPage;
    private int _rowsPerPage = 10;
    private bool _preferencesLoaded;
    private readonly CancellationTokenSource _pollingCancellationTokenSource = new();
    private bool _pollingPaused;

    // Snapshot of last-displayed data for change detection during polling
    private string? _lastDataFingerprint;

    // Filter state. The default Type selection shows everything except NotSet and Run Profile executions (which
    // have their own Operations page); this default writes no URL state.
    private static readonly IReadOnlyCollection<ActivityTargetType> DefaultTypeFilter = Enum.GetValues<ActivityTargetType>()
        .Where(t => t != ActivityTargetType.NotSet && t != ActivityTargetType.ConnectedSystemRunProfile)
        .ToList();
    private IReadOnlyCollection<ActivityTargetOperationType> _filterOperations = [];
    private IReadOnlyCollection<ActivityOutcomeType> _filterOutcomes = [];
    private IReadOnlyCollection<ActivityTargetType> _filterTypes = DefaultTypeFilter;
    private IReadOnlyCollection<ActivityStatus> _filterStatuses = [];
    private IReadOnlyCollection<ActivityInitiatorType> _filterInitiatorTypes = [];
    private DateRange? _filterDateRange;
    private ActivityTargetCategory? _selectedCategory;
    private bool _filterHasChildren;

    private bool IsAllCategorySelected => _selectedCategory == null && _filterTypes.Count == DefaultTypeFilter.Count &&
                                          !_filterTypes.Except(DefaultTypeFilter).Any();

    protected override async Task OnInitializedAsync()
    {
        NavManager.LocationChanged += OnLocationChanged;
        _currentPath = GetPathWithoutQuery(NavManager.Uri);
        _currentPage = GetPageFromUrl() - 1; // MudTable uses 0-indexed pages
        ApplyFiltersFromUrl();
        await UpdatePageStateAsync();

        // Setup polling for auto-refresh, only reloading when data has actually changed
        var token = _pollingCancellationTokenSource.Token;
        _ = Task.Run(async () =>
        {
            while (!token.IsCancellationRequested)
            {
                try
                {
                    await Task.Delay(TimeSpan.FromSeconds(5), token);

                    // Only auto-refresh when on page 1 and not paused to avoid jarring UX
                    if (_table == null || _currentPage != 0 || _pollingPaused)
                        continue;

                    // Fetch current data and compare with what's displayed
                    var operations = _filterOperations.Any() ? _filterOperations : null;
                    var outcomes = _filterOutcomes.Any() ? _filterOutcomes : null;
                    var types = _filterTypes.Any() ? _filterTypes : null;
                    var statuses = _filterStatuses.Any() ? _filterStatuses : null;
                    var initiatorTypes = _filterInitiatorTypes.Any() ? _filterInitiatorTypes : null;
                    var (createdFrom, createdTo) = GetCreatedRangeUtc();

                    using var pollJim = JimFactory.Create();
                    var result = await pollJim.Activities.GetActivitiesAsync(
                        1, _rowsPerPage,
                        string.IsNullOrWhiteSpace(_searchString) ? null : _searchString,
                        "created", true,
                        _currentUserId,
                        operations,
                        outcomes,
                        types,
                        statuses,
                        _filterHasChildren ? true : null,
                        initiatorTypes,
                        createdFrom,
                        createdTo);

                    var fingerprint = BuildFingerprint(result.Results);
                    if (fingerprint != _lastDataFingerprint)
                    {
                        await InvokeAsync(() => _table!.ReloadServerData());
                    }
                }
                catch (TaskCanceledException)
                {
                    break;
                }
                catch
                {
                    // Ignore errors during polling, will retry on next interval
                }
            }
        }, token);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_preferencesLoaded)
        {
            try
            {
                var preferredSize = await PreferenceService.GetRowsPerPageAsync();
                _rowsPerPage = preferredSize;
                _preferencesLoaded = true;
                StateHasChanged(); // Re-render to show the table now that preference is loaded
            }
            catch
            {
                // JS interop not yet available, will retry on next render
            }
        }
    }

    private async Task OnRowsPerPageChanged(int newSize)
    {
        _rowsPerPage = newSize;
        await PreferenceService.SetRowsPerPageAsync(newSize);
    }

    private int GetPageFromUrl()
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var pageStr = query["p"];
        if (int.TryParse(pageStr, out var page) && page > 0)
            return page;
        return 1; // Default to page 1
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        var newPath = GetPathWithoutQuery(e.Location);

        // Check if this is just a query string change (e.g., pagination update)
        // If so, don't reload the table as it's already being handled by ServerReload
        if (newPath == _currentPath)
            return;

        // Check if we're navigating away from the activity list pages entirely
        // If so, don't do any work - the component is being disposed
        var isActivityListPage = newPath.EndsWith("/activity", StringComparison.OrdinalIgnoreCase) ||
                                 newPath.EndsWith("/activity/mine", StringComparison.OrdinalIgnoreCase);
        if (!isActivityListPage)
            return;

        _currentPath = newPath;
        await UpdatePageStateAsync();
        await InvokeAsync(StateHasChanged);

        // Reload the table data when the actual path changes (e.g., /activity to /activity/mine)
        if (_table != null)
            await _table.ReloadServerData();
    }

    private static string GetPathWithoutQuery(string uri)
    {
        var questionMarkIndex = uri.IndexOf('?');
        return questionMarkIndex >= 0 ? uri[..questionMarkIndex] : uri;
    }

    private async Task UpdatePageStateAsync()
    {
        _isMyActivity = NavManager.Uri.EndsWith("/activity/mine", StringComparison.OrdinalIgnoreCase);

        if (_isMyActivity)
        {
            _pageTitle = "My Activity";
            _pageDescription = "View operations you have initiated, including synchronisations, configuration changes, and other actions.";

            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            _currentUserId = IdentityUtilities.GetUserId(authState.User);
        }
        else
        {
            _pageTitle = "Activity";
            _pageDescription = "Monitor all activity across the system. View operations initiated by users or automated processes, including synchronisations, configuration changes, and system events.";
            _currentUserId = null;
        }

        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", href: "/", icon: Icons.Material.Filled.Home),
            new(_pageTitle, href: null, disabled: true),
        };
    }

    public void Dispose()
    {
        _pollingCancellationTokenSource.Cancel();
        NavManager.LocationChanged -= OnLocationChanged;
    }

    private async Task<TableData<Activity>> ServerReload(TableState state, CancellationToken token)
    {
        _loading = true;
        StateHasChanged();

        try
        {
            // Convert MudBlazor's 0-indexed page to our 1-indexed page
            var page = state.Page + 1;
            var sortDescending = state.SortDirection == SortDirection.Descending;

            // Update URL with current page (without triggering navigation/reload)
            UpdateUrlWithPage(page);

            var operations = _filterOperations.Any() ? _filterOperations : null;
            var outcomes = _filterOutcomes.Any() ? _filterOutcomes : null;
            var types = _filterTypes.Any() ? _filterTypes : null;
            var statuses = _filterStatuses.Any() ? _filterStatuses : null;
            var initiatorTypes = _filterInitiatorTypes.Any() ? _filterInitiatorTypes : null;
            var (createdFrom, createdTo) = GetCreatedRangeUtc();

            using var jim = JimFactory.Create();
            var result = await jim.Activities.GetActivitiesAsync(
                page,
                state.PageSize,
                string.IsNullOrWhiteSpace(_searchString) ? null : _searchString,
                state.SortLabel,
                sortDescending,
                _currentUserId,
                operations,
                outcomes,
                types,
                statuses,
                _filterHasChildren ? true : null,
                initiatorTypes,
                createdFrom,
                createdTo);

            _childActivityCounts = await jim.Activities.GetChildActivityCountsAsync(result.Results.Select(a => a.Id));
            _lastDataFingerprint = BuildFingerprint(result.Results);

            return new TableData<Activity>
            {
                TotalItems = result.TotalResults,
                Items = result.Results
            };
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Writes the page number and every non-default filter into the URL query string (replacing the current history
    /// entry), so a filtered view is shareable and bookmarkable. Defaults write nothing, keeping the URL clean.
    /// </summary>
    private void UpdateUrlWithPage(int page)
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var baseUrl = uri.GetLeftPart(UriPartial.Path);

        var queryParams = new List<string>();
        if (page > 1)
            queryParams.Add($"p={page}");
        if (!string.IsNullOrWhiteSpace(_searchString))
            queryParams.Add($"q={Uri.EscapeDataString(_searchString)}");
        if (_selectedCategory != null)
            queryParams.Add($"cat={_selectedCategory}");
        else if (!IsAllCategorySelected && _filterTypes.Any())
            queryParams.Add($"type={string.Join(',', _filterTypes)}");
        if (_filterOperations.Any())
            queryParams.Add($"op={string.Join(',', _filterOperations)}");
        if (_filterOutcomes.Any())
            queryParams.Add($"outcome={string.Join(',', _filterOutcomes)}");
        if (_filterStatuses.Any())
            queryParams.Add($"status={string.Join(',', _filterStatuses)}");
        if (_filterInitiatorTypes.Any())
            queryParams.Add($"init={string.Join(',', _filterInitiatorTypes)}");
        if (_filterDateRange?.Start != null)
            queryParams.Add($"from={_filterDateRange.Start:yyyy-MM-dd}");
        if (_filterDateRange?.End != null)
            queryParams.Add($"to={_filterDateRange.End:yyyy-MM-dd}");
        if (_filterHasChildren)
            queryParams.Add("kids=1");

        var newUrl = queryParams.Count > 0 ? $"{baseUrl}?{string.Join('&', queryParams)}" : baseUrl;

        // Update URL without navigation (replace current history entry)
        NavManager.NavigateTo(newUrl, replace: true);
    }

    /// <summary>
    /// Seeds the filter state from the URL query string on first load, so a shared or bookmarked filtered view
    /// reproduces exactly. An explicit type list takes precedence over a category.
    /// </summary>
    private void ApplyFiltersFromUrl()
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);

        var search = query["q"];
        if (!string.IsNullOrWhiteSpace(search))
            _searchString = search;

        var types = ParseEnumList<ActivityTargetType>(query["type"]);
        if (types.Count > 0)
        {
            _filterTypes = types;
        }
        else if (Enum.TryParse<ActivityTargetCategory>(query["cat"], ignoreCase: true, out var category))
        {
            _selectedCategory = category;
            _filterTypes = ActivityTargetTypeCategories.GetTargetTypes(category);
        }

        var operations = ParseEnumList<ActivityTargetOperationType>(query["op"]);
        if (operations.Count > 0)
            _filterOperations = operations;

        var outcomes = ParseEnumList<ActivityOutcomeType>(query["outcome"]);
        if (outcomes.Count > 0)
            _filterOutcomes = outcomes;

        var statuses = ParseEnumList<ActivityStatus>(query["status"]);
        if (statuses.Count > 0)
            _filterStatuses = statuses;

        var initiatorTypes = ParseEnumList<ActivityInitiatorType>(query["init"]);
        if (initiatorTypes.Count > 0)
            _filterInitiatorTypes = initiatorTypes;

        DateTime? from = DateTime.TryParse(query["from"], out var fromDate) ? fromDate : null;
        DateTime? to = DateTime.TryParse(query["to"], out var toDate) ? toDate : null;
        if (from != null || to != null)
            _filterDateRange = new DateRange(from, to);

        if (query["kids"] == "1")
            _filterHasChildren = true;
    }

    private static List<T> ParseEnumList<T>(string? value) where T : struct, Enum
    {
        if (string.IsNullOrWhiteSpace(value))
            return [];
        return value.Split(',', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries)
            .Select(part => Enum.TryParse<T>(part, ignoreCase: true, out var parsed) ? parsed : (T?)null)
            .Where(parsed => parsed.HasValue)
            .Select(parsed => parsed!.Value)
            .ToList();
    }

    /// <summary>
    /// Converts the picked local date range into an inclusive UTC window: the whole of the start day through the
    /// whole of the end day.
    /// </summary>
    private (DateTime? createdFrom, DateTime? createdTo) GetCreatedRangeUtc()
    {
        DateTime? from = _filterDateRange?.Start?.Date.ToUniversalTime();
        DateTime? to = _filterDateRange?.End?.Date.AddDays(1).AddTicks(-1).ToUniversalTime();
        return (from, to);
    }

    private void OnSearch(string text)
    {
        _searchString = text;
        _table?.ReloadServerData();
    }

    private void HandleRowClick(TableRowClickEventArgs<Activity> args)
    {
        // Prevent navigation while data is loading to avoid concurrent EF operations
        if (_loading || args.Item == null)
            return;

        // Navigate using absolute path to ensure no query params are carried over
        var uri = NavManager.ToAbsoluteUri($"/activity/{args.Item.Id}");
        NavManager.NavigateTo(uri.AbsolutePath);
    }

    /// <summary>
    /// Checks whether an activity has any granular stats to display.
    /// </summary>
    private static bool HasAnyStats(Activity activity)
    {
        return activity.TotalAdded > 0
            || activity.TotalUpdated > 0
            || activity.TotalDeleted > 0
            || activity.TotalProjected > 0
            || activity.TotalJoined > 0
            || activity.TotalAttributeFlows > 0
            || activity.TotalDisconnected > 0
            || activity.TotalDisconnectedOutOfScope > 0
            || activity.TotalOutOfScopeRetainJoin > 0
            || activity.TotalDriftCorrections > 0
            || activity.TotalProvisioned > 0
            || activity.TotalExported > 0
            || activity.TotalDeprovisioned > 0
            || activity.TotalCreated > 0
            || activity.TotalPendingExports > 0
            || activity.TotalErrors > 0;
    }

    private void OnOperationFilterChanged(IReadOnlyCollection<ActivityTargetOperationType> values)
    {
        _filterOperations = values;
        _table?.ReloadServerData();
    }

    private void OnOutcomeFilterChanged(IReadOnlyCollection<ActivityOutcomeType> values)
    {
        _filterOutcomes = values;
        _table?.ReloadServerData();
    }

    private void OnTypeFilterChanged(IReadOnlyCollection<ActivityTargetType> values)
    {
        // A manual type selection overrides any category quick-filter choice.
        _selectedCategory = null;
        _filterTypes = values;
        _table?.ReloadServerData();
    }

    private Task OnCategorySelectedAsync(ActivityTargetCategory? category)
    {
        _selectedCategory = category;
        _filterTypes = category == null ? DefaultTypeFilter : ActivityTargetTypeCategories.GetTargetTypes(category.Value);
        return _table?.ReloadServerData() ?? Task.CompletedTask;
    }

    private void OnInitiatorTypeFilterChanged(IReadOnlyCollection<ActivityInitiatorType> values)
    {
        _filterInitiatorTypes = values;
        _table?.ReloadServerData();
    }

    private void OnDateRangeChanged(DateRange? range)
    {
        // Treat a cleared or empty range as no date filter.
        _filterDateRange = range == null || (range.Start == null && range.End == null) ? null : range;
        _table?.ReloadServerData();
    }

    private static string GetCategoryLabel(ActivityTargetCategory category) => category switch
    {
        ActivityTargetCategory.Configuration => "Configuration",
        ActivityTargetCategory.IdentityData => "Identity",
        ActivityTargetCategory.SyncRuns => "Synchronisation",
        ActivityTargetCategory.System => "System",
        _ => category.ToString()
    };

    private void OnStatusFilterChanged(IReadOnlyCollection<ActivityStatus> values)
    {
        _filterStatuses = values;
        _table?.ReloadServerData();
    }

    private void OnHasChildrenFilterChanged(bool value)
    {
        _filterHasChildren = value;
        _table?.ReloadServerData();
    }

    private static string GetMultiSelectText(IReadOnlyList<string> selectedValues)
    {
        return selectedValues.Count switch
        {
            0 => string.Empty,
            1 => selectedValues[0],
            _ => $"{selectedValues.Count} selected"
        };
    }

    /// <summary>
    /// Builds a lightweight fingerprint of the current result set for change detection.
    /// Captures identity, status, and a representative subset of granular stats so polling
    /// only triggers a reload when data actually changed.
    /// </summary>
    private static string BuildFingerprint(IEnumerable<Activity> activities)
    {
        return string.Join("|", activities.Select(a =>
            $"{a.Id}:{a.Status}:{a.TotalAdded},{a.TotalUpdated},{a.TotalDeleted},{a.TotalProjected},{a.TotalJoined},{a.TotalAttributeFlows},{a.TotalDisconnected},{a.TotalDriftCorrections},{a.TotalProvisioned},{a.TotalExported},{a.TotalDeprovisioned},{a.TotalErrors},{a.TotalCreated}"));
    }

    /// <summary>
    /// Determines the effective run type category from the enum or target name fallback.
    /// </summary>
    private static string GetEffectiveRunType(ConnectedSystemRunType? runType, string? targetName)
    {
        // Check enum first
        if (runType is ConnectedSystemRunType.FullImport or ConnectedSystemRunType.DeltaImport)
            return "Import";
        if (runType is ConnectedSystemRunType.FullSynchronisation or ConnectedSystemRunType.DeltaSynchronisation)
            return "Sync";
        if (runType is ConnectedSystemRunType.Export)
            return "Export";

        // Fallback to target name if run type is NotSet or null
        if (!string.IsNullOrEmpty(targetName))
        {
            if (targetName.Contains("Import", StringComparison.OrdinalIgnoreCase))
                return "Import";
            if (targetName.Contains("Sync", StringComparison.OrdinalIgnoreCase))
                return "Sync";
            if (targetName.Contains("Export", StringComparison.OrdinalIgnoreCase))
                return "Export";
        }

        return "Unknown";
    }
}
