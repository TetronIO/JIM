@page "/admin/operations"
@using JIM.Web.Pages.Admin.Components
@attribute [Authorize(Roles = "Administrator")]
@inject IJimApplicationFactory JimFactory

<PageTitle>Operations</PageTitle>
<MudText Typo="Typo.h4"><MudIcon Icon="@Icons.Material.Filled.PendingActions" Size="Size.Large" Class="mr-2 mb-1" Style="vertical-align: middle;" />Operations</MudText>
<MudBreadcrumbs Items="_breadcrumbs" Class="ps-0"></MudBreadcrumbs>
<MudText Typo="Typo.subtitle1" Class="mud-text-secondary">
    Manage tasks, view execution history, and configure schedules.
</MudText>

<MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="false" Outlined="true" PanelClass="pt-5" Class="mt-5">
    <MudTabPanel Text="Queue" Icon="@Icons.Material.Filled.Queue">
        <OperationsQueueTab />
    </MudTabPanel>
    <MudTabPanel Text="History" Icon="@Icons.Material.Filled.History">
        <OperationsHistoryTab />
    </MudTabPanel>
    <MudTabPanel Text="Schedules" Icon="@Icons.Material.Filled.Schedule">
        <OperationsSchedulesTab />
    </MudTabPanel>
</MudTabs>

@code {
    private readonly List<BreadcrumbItem> _breadcrumbs =
    [
        new("Home", href: "/", icon: Icons.Material.Filled.Home),
        new("Operations", href: null, disabled: true)
    ];
}
