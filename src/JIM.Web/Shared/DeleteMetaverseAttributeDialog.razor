@using JIM.Models.Core
@using JIM.Models.Core.DTOs
@using JIM.Web.Services
@inject IJimApplicationFactory JimFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        @if (_impact == null)
        {
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        }
        else
        {
            <MudStack Spacing="4">
                @if (_impact.BlockedByValues)
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">
                        <MudText Typo="Typo.subtitle2">@_impact.TotalObjectsWithValues.ToString("N0") object(s) have a value</MudText>
                        <MudList T="string" Dense="true" Class="mt-1">
                            @foreach (var count in _impact.ObjectTypeValueCounts)
                            {
                                <MudListItem T="string" Icon="@Icons.Material.Filled.Person">
                                    @count.MetaverseObjectTypeName: <b>@count.ObjectCount.ToString("N0")</b> with a value
                                </MudListItem>
                            }
                        </MudList>
                    </MudAlert>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">
                        Clear these values first (stop the source flow and let it deprovision, or bulk-clear), then delete.
                    </MudText>
                }
                else
                {
                    <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true">
                        No object holds a value for this attribute. Safe to delete; no object data will be lost.
                    </MudAlert>

                    @if (_impact.References.Count > 0)
                    {
                        <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined">
                            <MudText Typo="Typo.subtitle2">These @_impact.References.Count reference(s) will also be removed</MudText>
                            <MudList T="string" Dense="true" Class="mt-1">
                                @foreach (var reference in _impact.References)
                                {
                                    <MudListItem T="string" Icon="@Icons.Material.Filled.Link">
                                        @reference.Description
                                    </MudListItem>
                                }
                            </MudList>
                        </MudAlert>

                        <div>
                            <MudText Typo="Typo.body2" Class="mb-1">Type <b>@_impact.AttributeName</b> to confirm</MudText>
                            <MudTextField @bind-Value="_confirmText" Variant="Variant.Outlined" Immediate="true"
                                          Placeholder="@_impact.AttributeName" AutoFocus="true"
                                          Adornment="Adornment.End"
                                          AdornmentIcon="@(ConfirmMatches() ? Icons.Material.Filled.CheckCircle : null)" />
                        </div>
                    }
                }
            </MudStack>
        }
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">@(_impact?.BlockedByValues == true ? "Close" : "Cancel")</MudButton>
        <MudButton Color="Color.Error" Variant="Variant.Filled"
                   Disabled="@(!CanDelete())" OnClick="DeleteAsync">
            @DeleteButtonText()
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    /// <summary>
    /// The attribute to delete.
    /// </summary>
    [Parameter]
    public MetaverseAttribute Attribute { get; set; } = null!;

    private AttributeDeletionImpact? _impact;
    private string _confirmText = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        using var jim = JimFactory.Create();
        _impact = await jim.Metaverse.EvaluateAttributeDeletionAsync(Attribute);
    }

    private bool ConfirmMatches() =>
        _impact != null && string.Equals(_confirmText, _impact.AttributeName, StringComparison.Ordinal);

    private bool CanDelete()
    {
        if (_impact == null || _impact.BlockedByValues || _impact.BuiltIn)
            return false;

        // References present require the typed confirmation; unreferenced deletes do not.
        return _impact.References.Count == 0 || ConfirmMatches();
    }

    private string DeleteButtonText()
    {
        if (_impact == null)
            return "Delete";
        return _impact.References.Count > 0
            ? $"Delete + {_impact.References.Count} reference(s)"
            : "Delete";
    }

    private async Task DeleteAsync()
    {
        var (cancelled, changeReason) = await ChangeReasonDialog.ShowAsync(DialogService, "Delete");
        if (cancelled)
            return;

        try
        {
            using var jim = JimFactory.Create();
            var user = await Helpers.GetUserAsync(jim, AuthenticationStateTask);
            var impact = await jim.Metaverse.DeleteMetaverseAttributeWithCascadeAsync(Attribute, user, changeReason);
            if (!impact.Deleted)
            {
                Snackbar.Add("The attribute could not be deleted; it may now hold stored values. Refresh and try again.", Severity.Warning);
                return;
            }
            Snackbar.Add($"Deleted attribute \"{impact.AttributeName}\".", Severity.Success);
        }
        catch (Exception ex) when (ex is not OperationCanceledException)
        {
            Snackbar.Add($"Failed to delete attribute: {ex.Message}", Severity.Error);
            return;
        }

        MudDialog.Close(DialogResult.Ok(true));
    }

    private void Cancel() => MudDialog.Cancel();

    /// <summary>
    /// Opens the delete dialog for a Metaverse Attribute. Returns true when the attribute was deleted.
    /// </summary>
    public static async Task<bool> ShowAsync(IDialogService dialogService, MetaverseAttribute attribute)
    {
        var parameters = new DialogParameters<DeleteMetaverseAttributeDialog>
        {
            { x => x.Attribute, attribute }
        };
        var options = new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await dialogService.ShowAsync<DeleteMetaverseAttributeDialog>($"Delete \"{attribute.Name}\" Attribute", parameters, options);
        var result = await dialog.Result;
        return result is { Canceled: false, Data: true };
    }
}
