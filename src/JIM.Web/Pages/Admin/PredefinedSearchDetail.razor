@page "/admin/predefined-searches/{Uri}"
@attribute [Authorize(Roles = "Administrator")]
@using JIM.Models.Core
@using JIM.Models.Search
@using JIM.Utilities
@inject IJimApplicationFactory JimFactory
@inject NavigationManager NavManager
@inject ISnackbar Snackbar

@* Copyright (c) Tetron Limited. All rights reserved. *@
@* Licensed under the Tetron Commercial License. See LICENSE file in the project root. *@

<PageTitle>Predefined Search: @_predefinedSearch?.Name</PageTitle>
<MudText Typo="Typo.h4"><MudIcon Icon="@Icons.Material.Filled.SavedSearch" Size="Size.Large" Class="mr-2 mb-1" Style="vertical-align: middle;" /><span>Predefined Search:</span> <span class="mud-primary-text">@_predefinedSearch?.Name</span></MudText>
<div class="d-flex justify-space-between align-center">
    <MudBreadcrumbs Items="_breadcrumbs" Class="ps-0"></MudBreadcrumbs>
    @if (_predefinedSearch != null)
    {
        <AuditInfo Entity="@_predefinedSearch" />
    }
</div>

@if (_predefinedSearch != null)
{
    <MudPaper Class="pa-4" Outlined="true">
        <MudText Typo="Typo.h5" Class="mb-3">Details</MudText>
        <MudGrid Spacing="4">
            <MudItem xs="12" sm="6" md="4">
                <MudField Label="Name" Variant="Variant.Outlined">@_predefinedSearch.Name</MudField>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudField Label="Uri" Variant="Variant.Outlined">@_predefinedSearch.Uri</MudField>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudField Label="Object Type" Variant="Variant.Outlined">@_predefinedSearch.MetaverseObjectType.Name</MudField>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudField Label="Is default for Object Type?" Variant="Variant.Outlined">@(_predefinedSearch.IsDefaultForMetaverseObjectType ? "Yes" : "No")</MudField>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudField Label="Built-in?" Variant="Variant.Outlined">@(_predefinedSearch.BuiltIn ? "Yes" : "No")</MudField>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudSwitch T="bool" Value="_predefinedSearch.IsEnabled" Color="Color.Success"
                           Label="Enabled" ValueChanged="async (bool val) => await ToggleEnabledAsync(val)" />
                <MudText Typo="Typo.caption" Class="mud-text-secondary">Disabled searches don't appear on the portal.</MudText>
            </MudItem>
        </MudGrid>
    </MudPaper>

    <MudPaper Class="pa-4 mt-6" Outlined="true">
        <MudText Typo="Typo.h5">Metaverse Attributes</MudText>
        <MudText Typo="Typo.subtitle1" Class="mud-text-secondary mb-3">These will be the attributes shown in the search results:</MudText>
        <div>
            @foreach (var psa in _predefinedSearch.Attributes)
            {
                <MudChip T="string" Color="Color.Primary">@psa.MetaverseAttribute.Name</MudChip>
            }
        </div>
    </MudPaper>

    <MudPaper Class="pa-4 mt-6" Outlined="true">
        <div class="d-flex justify-space-between align-center mb-3">
            <div>
                <MudText Typo="Typo.h5">Criteria</MudText>
                <MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Criteria filter the objects this search returns. All criteria are combined with AND.</MudText>
            </div>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Color="Color.Primary"
                       OnClick="HandleOpenAddGroupDialog" DropShadow="false">Add Criteria Group</MudButton>
        </div>

        @if (_predefinedSearch.CriteriaGroups.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">This search has no criteria; it returns all @_predefinedSearch.MetaverseObjectType.Name objects. Add a Criteria Group to start filtering.</MudAlert>
        }
        else
        {
            <MudStack>
                @foreach (var criteriaGroup in _predefinedSearch.CriteriaGroups.OrderBy(g => g.Position))
                {
                    <MudPaper Class="pa-5" Outlined="true">
                        @RenderGroupHeader(criteriaGroup)
                        @RenderCriteria(criteriaGroup)

                        <div class="mt-4">
                            <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Class="me-3"
                                       OnClick="@(() => HandleOpenAddCriteriaDialog(criteriaGroup.Id))" DropShadow="false">Add Criteria</MudButton>
                            <MudButton StartIcon="@Icons.Material.Filled.AccountTree" Variant="Variant.Filled"
                                       OnClick="@(() => HandleOpenAddChildGroupDialog(criteriaGroup.Id))" DropShadow="false">Add Criteria Group</MudButton>
                        </div>

                        @foreach (var childGroup in criteriaGroup.ChildGroups.OrderBy(g => g.Position))
                        {
                            <MudPaper Class="pa-5 mt-4 ml-6" Outlined="true">
                                @RenderGroupHeader(childGroup)
                                @RenderCriteria(childGroup)
                                <MudButton StartIcon="@Icons.Material.Filled.Add" Variant="Variant.Filled" Class="mt-4"
                                           OnClick="@(() => HandleOpenAddCriteriaDialog(childGroup.Id))" DropShadow="false">Add Criteria</MudButton>
                            </MudPaper>
                        }
                    </MudPaper>
                }
            </MudStack>
        }
    </MudPaper>

    @* ─── Add Criteria Group dialog ─── *@
    <MudDialog @bind-Visible="_addGroupDialogVisible" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6"><MudIcon Icon="@Icons.Material.Filled.AccountTree" Class="mr-3" /> Add Criteria Group</MudText>
        </TitleContent>
        <DialogContent>
            <MudSelect T="string" Label="Logic type" Required="true" Variant="Variant.Outlined" @bind-Value="_newGroupType">
                @foreach (var type in Enum.GetValues(typeof(SearchGroupType)))
                {
                    <MudSelectItem Value="@type.ToString()" />
                }
            </MudSelect>
        </DialogContent>
        <DialogActions>
            <MudButton DropShadow="false" Variant="Variant.Filled" Color="Color.Default" OnClick="@(() => _addGroupDialogVisible = false)" Class="me-2">Cancel</MudButton>
            <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="string.IsNullOrEmpty(_newGroupType)" OnClick="HandleAddGroupAsync" DropShadow="false">Add Group</MudButton>
        </DialogActions>
    </MudDialog>

    @* ─── Add/Edit Criteria dialog ─── *@
    <MudDialog @bind-Visible="_addCriteriaDialogVisible" Options="_dialogOptions">
        <TitleContent>
            <MudText Typo="Typo.h6"><MudIcon Icon="@Icons.Material.Filled.Compare" Class="mr-3" /> @(_editingCriterionId.HasValue ? "Edit Criteria" : "Add Criteria")</MudText>
        </TitleContent>
        <DialogContent>
            @if (_newCriterion != null)
            {
                <MudSelect T="MetaverseAttribute"
                           Value="_newCriterionAttribute"
                           ValueChanged="HandleAttributeSelection"
                           Label="Metaverse Attribute"
                           Placeholder="Please select a Metaverse attribute"
                           Required="true"
                           Class="mt-5"
                           Variant="Variant.Outlined"
                           ToStringFunc="@(a => a?.Name ?? string.Empty)">
                    @foreach (var attr in _objectTypeAttributes.OrderBy(a => a.Name))
                    {
                        <MudSelectItem Value="@attr">@attr.Name</MudSelectItem>
                    }
                </MudSelect>

                @if (_newCriterionAttribute != null)
                {
                    <MudSelect T="SearchComparisonType"
                               @bind-Value="_newCriterion.ComparisonType"
                               Label="Comparison Type"
                               Placeholder="Please select the type of comparison to make"
                               Required="true"
                               Class="mt-5"
                               Variant="Variant.Outlined">
                        @foreach (var op in GetOperatorsForType(_newCriterionAttribute.Type))
                        {
                            <MudSelectItem Value="@op.Operator">@op.Label</MudSelectItem>
                        }
                    </MudSelect>

                    <CriterionValueEditor Criterion="_newCriterion" AttributeType="_newCriterionAttribute.Type" OnChanged="StateHasChanged" />
                }
            }
        </DialogContent>
        <DialogActions>
            <MudButton DropShadow="false" Variant="Variant.Filled" Color="Color.Default" OnClick="@(() => _addCriteriaDialogVisible = false)" Class="me-2">Cancel</MudButton>
            <MudButton Disabled="DisableAddCriteriaButton()" Variant="Variant.Filled" DropShadow="false" Color="Color.Primary" OnClick="HandleSaveCriterionAsync">@(_editingCriterionId.HasValue ? "Save" : "Add Criteria")</MudButton>
        </DialogActions>
    </MudDialog>
}

@code {
    [Parameter]
    public string? Uri { get; set; }

    private PredefinedSearch? _predefinedSearch;
    private List<BreadcrumbItem> _breadcrumbs = null!;

    // Attributes of the search's Metaverse Object Type, for the criterion attribute picker.
    private List<MetaverseAttribute> _objectTypeAttributes = new();

    private readonly DialogOptions _dialogOptions = new() { FullWidth = true };

    // Add Criteria Group dialog state.
    private bool _addGroupDialogVisible;
    private string? _newGroupType;
    private int? _addGroupParentId;

    // Add/Edit Criteria dialog state.
    private bool _addCriteriaDialogVisible;
    private int _addCriteriaGroupId;
    private int? _editingCriterionId;
    private PredefinedSearchCriteria? _newCriterion;
    private MetaverseAttribute? _newCriterionAttribute;

    private sealed record OperatorOption(SearchComparisonType Operator, string Label);

    // ─── Render helpers (shared by top-level and nested groups) ───

    private RenderFragment RenderGroupHeader(PredefinedSearchCriteriaGroup group) =>@<div class="d-flex justify-space-between align-center">
        <MudText Typo="Typo.overline"><span class="mud-text-secondary">CRITERIA GROUP. LOGIC TYPE:</span> @group.Type.ToString().SplitOnCapitalLetters().ToUpper()</MudText>
        <MudTooltip Text="Delete group" Arrow="true" Placement="Placement.Top">
            <MudIconButton Icon="@Icons.Material.Outlined.Delete" Variant="Variant.Filled" Color="Color.Error" Size="Size.Small" DropShadow="false"
                           aria-label="delete group" OnClick="@(() => HandleDeleteGroupAsync(group.Id))" />
        </MudTooltip>
    </div>;

    private RenderFragment RenderCriteria(PredefinedSearchCriteriaGroup group) =>@<text>
        @if (group.Criteria.Count == 0)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-3">No criteria in this group yet.</MudAlert>
        }
        @foreach (var criteria in group.Criteria)
        {
            <div class="mt-3 d-flex align-center">
                <MudChip T="string">
                    <AvatarContent>
                        <MudTooltip Text="Metaverse Attribute" Arrow="true" Placement="Placement.Top">
                            <MudAvatar Color="Color.Primary">MV</MudAvatar>
                        </MudTooltip>
                    </AvatarContent>
                    <ChildContent>@criteria.GetAttributeName()</ChildContent>
                </MudChip>
                <MudChip T="string">@FriendlyComparison(criteria)</MudChip>
                <MudChip T="string">@criteria.ToString()</MudChip>
                <MudTooltip Text="Edit criteria" Arrow="true" Placement="Placement.Top">
                    <MudIconButton Icon="@Icons.Material.Outlined.Edit" Size="Size.Small" DropShadow="false"
                                   aria-label="edit criteria" OnClick="@(() => HandleOpenEditCriteriaDialog(criteria))" />
                </MudTooltip>
                <MudTooltip Text="Delete criteria" Arrow="true" Placement="Placement.Top">
                    <MudIconButton Icon="@Icons.Material.Outlined.Delete" Size="Size.Small" DropShadow="false"
                                   aria-label="delete criteria" OnClick="@(() => HandleDeleteCriterionAsync(criteria.Id))" />
                </MudTooltip>
            </div>
        }
    </text>;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrEmpty(Uri))
        {
            // no predefined search parameter passed in, redirect to index page
            NavManager.NavigateTo("../");
            return;
        }

        using var jim = JimFactory.Create();
        _predefinedSearch = await jim.Search.GetPredefinedSearchAsync(Uri);
        if (_predefinedSearch == null)
        {
            // predefined search not found, redirect to index page
            NavManager.NavigateTo("../");
            return;
        }

        // Load the object type's attributes so the criterion editor can offer them.
        var objectType = await jim.Metaverse.GetMetaverseObjectTypeAsync(_predefinedSearch.MetaverseObjectType.Id, includeChildObjects: true);
        _objectTypeAttributes = objectType?.Attributes ?? new List<MetaverseAttribute>();

        _breadcrumbs = new List<BreadcrumbItem>
        {
            new("Home", href: "/", icon: Icons.Material.Filled.Home),
            new("Administration", href: "/admin"),
            new("Predefined Searches", href: "/admin/predefined-searches/"),
            new(_predefinedSearch.Name, href: null, disabled: true)
        };
    }

    private async Task ReloadAsync()
    {
        if (string.IsNullOrEmpty(Uri))
            return;

        using var jim = JimFactory.Create();
        _predefinedSearch = await jim.Search.GetPredefinedSearchAsync(Uri);
    }

    // ─── Criteria group operations ───

    private void HandleOpenAddGroupDialog()
    {
        _addGroupParentId = null;
        _newGroupType = SearchGroupType.All.ToString();
        _addGroupDialogVisible = true;
    }

    private void HandleOpenAddChildGroupDialog(int parentGroupId)
    {
        _addGroupParentId = parentGroupId;
        _newGroupType = SearchGroupType.Any.ToString();
        _addGroupDialogVisible = true;
    }

    private async Task HandleAddGroupAsync()
    {
        if (_predefinedSearch == null || string.IsNullOrEmpty(_newGroupType))
            return;

        var type = (SearchGroupType)Enum.Parse(typeof(SearchGroupType), _newGroupType);

        // Position among siblings: child groups order within their parent, top-level groups among themselves.
        int position;
        if (_addGroupParentId.HasValue)
        {
            var parent = FindGroup(_predefinedSearch.CriteriaGroups, _addGroupParentId.Value);
            position = parent?.ChildGroups.Count ?? 0;
        }
        else
        {
            position = _predefinedSearch.CriteriaGroups.Count;
        }

        try
        {
            using var jim = JimFactory.Create();
            await jim.Search.CreatePredefinedSearchCriteriaGroupAsync(_predefinedSearch.Id, _addGroupParentId, type, position);
            _addGroupDialogVisible = false;
            await ReloadAsync();
            Snackbar.Add("Criteria group added.", Severity.Success);
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add($"Failed to add criteria group: {ex.Message}", Severity.Error);
        }
    }

    private static PredefinedSearchCriteriaGroup? FindGroup(IEnumerable<PredefinedSearchCriteriaGroup> groups, int groupId)
    {
        foreach (var group in groups)
        {
            if (group.Id == groupId)
                return group;
            var match = FindGroup(group.ChildGroups, groupId);
            if (match != null)
                return match;
        }
        return null;
    }

    private async Task HandleDeleteGroupAsync(int groupId)
    {
        try
        {
            using var jim = JimFactory.Create();
            await jim.Search.DeletePredefinedSearchCriteriaGroupAsync(groupId);
            await ReloadAsync();
            Snackbar.Add("Criteria group deleted.", Severity.Success);
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add($"Failed to delete criteria group: {ex.Message}", Severity.Error);
        }
    }

    // ─── Criterion operations ───

    private void HandleOpenAddCriteriaDialog(int groupId)
    {
        _addCriteriaGroupId = groupId;
        _editingCriterionId = null;
        _newCriterion = new PredefinedSearchCriteria();
        _newCriterionAttribute = null;
        _addCriteriaDialogVisible = true;
    }

    private void HandleOpenEditCriteriaDialog(PredefinedSearchCriteria criteria)
    {
        _editingCriterionId = criteria.Id;
        // Work on a copy so cancelling the dialog leaves the displayed criterion untouched.
        _newCriterion = new PredefinedSearchCriteria
        {
            Id = criteria.Id,
            ComparisonType = criteria.ComparisonType,
            MetaverseAttributeId = criteria.MetaverseAttribute?.Id ?? criteria.MetaverseAttributeId,
            StringValue = criteria.StringValue,
            IntValue = criteria.IntValue,
            LongValue = criteria.LongValue,
            DateTimeValue = criteria.DateTimeValue,
            BoolValue = criteria.BoolValue,
            GuidValue = criteria.GuidValue,
            CaseSensitive = criteria.CaseSensitive,
            ValueMode = criteria.ValueMode,
            RelativeCount = criteria.RelativeCount,
            RelativeUnit = criteria.RelativeUnit,
            RelativeDirection = criteria.RelativeDirection
        };
        var attributeId = criteria.MetaverseAttribute?.Id ?? criteria.MetaverseAttributeId;
        _newCriterionAttribute = _objectTypeAttributes.FirstOrDefault(a => a.Id == attributeId) ?? criteria.MetaverseAttribute;
        _addCriteriaDialogVisible = true;
    }

    private void HandleAttributeSelection(MetaverseAttribute attribute)
    {
        _newCriterionAttribute = attribute;
        if (_newCriterion != null)
        {
            // Reset operator/value when the attribute (and therefore its data type) changes.
            _newCriterion.ComparisonType = SearchComparisonType.NotSet;
            _newCriterion.StringValue = null;
            _newCriterion.IntValue = null;
            _newCriterion.LongValue = null;
            _newCriterion.DateTimeValue = null;
            _newCriterion.BoolValue = null;
            _newCriterion.GuidValue = null;
        }
    }

    private async Task HandleSaveCriterionAsync()
    {
        if (_predefinedSearch == null || _newCriterion == null || _newCriterionAttribute == null)
            return;

        _newCriterion.MetaverseAttributeId = _newCriterionAttribute.Id;
        var editing = _editingCriterionId.HasValue;
        try
        {
            using var jim = JimFactory.Create();
            if (editing)
                await jim.Search.UpdatePredefinedSearchCriterionAsync(_newCriterion);
            else
                await jim.Search.CreatePredefinedSearchCriterionAsync(_addCriteriaGroupId, _newCriterion);

            _addCriteriaDialogVisible = false;
            _newCriterion = null;
            _newCriterionAttribute = null;
            _editingCriterionId = null;
            await ReloadAsync();
            Snackbar.Add(editing ? "Criteria updated." : "Criteria added.", Severity.Success);
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add($"Failed to save criteria: {ex.Message}", Severity.Error);
        }
    }

    private async Task HandleDeleteCriterionAsync(int criterionId)
    {
        try
        {
            using var jim = JimFactory.Create();
            await jim.Search.DeletePredefinedSearchCriterionAsync(criterionId);
            await ReloadAsync();
            Snackbar.Add("Criteria deleted.", Severity.Success);
        }
        catch (ArgumentException ex)
        {
            Snackbar.Add($"Failed to delete criteria: {ex.Message}", Severity.Error);
        }
    }

    private bool DisableAddCriteriaButton()
    {
        if (_newCriterion == null || _newCriterionAttribute == null)
            return true;
        if (_newCriterion.ComparisonType == SearchComparisonType.NotSet)
            return true;

        return _newCriterionAttribute.Type switch
        {
            AttributeDataType.Text => string.IsNullOrEmpty(_newCriterion.StringValue),
            AttributeDataType.Guid => !_newCriterion.GuidValue.HasValue,
            AttributeDataType.Number => !_newCriterion.IntValue.HasValue,
            AttributeDataType.LongNumber => !_newCriterion.LongValue.HasValue,
            AttributeDataType.DateTime => _newCriterion.ValueMode == DateCriteriaValueMode.Relative
                ? !(_newCriterion.RelativeCount.HasValue && _newCriterion.RelativeUnit.HasValue && _newCriterion.RelativeDirection.HasValue)
                : !_newCriterion.DateTimeValue.HasValue,
            AttributeDataType.Boolean => !_newCriterion.BoolValue.HasValue,
            _ => true
        };
    }

    /// <summary>
    /// Returns the comparison operators applicable to a data type, with friendly labels.
    /// DateTime uses prior-art wording (before / on or before / after / on or after).
    /// </summary>
    private static List<OperatorOption> GetOperatorsForType(AttributeDataType type)
    {
        switch (type)
        {
            case AttributeDataType.Text:
                return new()
                {
                    new(SearchComparisonType.Equals, "equals"),
                    new(SearchComparisonType.NotEquals, "does not equal"),
                    new(SearchComparisonType.StartsWith, "starts with"),
                    new(SearchComparisonType.NotStartsWith, "does not start with"),
                    new(SearchComparisonType.EndsWith, "ends with"),
                    new(SearchComparisonType.NotEndsWith, "does not end with"),
                    new(SearchComparisonType.Contains, "contains"),
                    new(SearchComparisonType.NotContains, "does not contain")
                };
            case AttributeDataType.DateTime:
                return new()
                {
                    new(SearchComparisonType.LessThan, "before"),
                    new(SearchComparisonType.LessThanOrEquals, "on or before"),
                    new(SearchComparisonType.GreaterThan, "after"),
                    new(SearchComparisonType.GreaterThanOrEquals, "on or after"),
                    new(SearchComparisonType.Equals, "equals"),
                    new(SearchComparisonType.NotEquals, "does not equal")
                };
            case AttributeDataType.Number:
            case AttributeDataType.LongNumber:
                return new()
                {
                    new(SearchComparisonType.Equals, "equals"),
                    new(SearchComparisonType.NotEquals, "does not equal"),
                    new(SearchComparisonType.LessThan, "less than"),
                    new(SearchComparisonType.LessThanOrEquals, "less than or equal to"),
                    new(SearchComparisonType.GreaterThan, "greater than"),
                    new(SearchComparisonType.GreaterThanOrEquals, "greater than or equal to")
                };
            case AttributeDataType.Boolean:
            case AttributeDataType.Guid:
                return new()
                {
                    new(SearchComparisonType.Equals, "equals"),
                    new(SearchComparisonType.NotEquals, "does not equal")
                };
            default:
                return new();
        }
    }

    /// <summary>
    /// Renders a criterion's comparison operator in friendly wording (DateTime uses the prior-art labels).
    /// </summary>
    private static string FriendlyComparison(PredefinedSearchCriteria criteria)
    {
        var type = criteria.GetAttributeDataType();
        if (type.HasValue)
        {
            var match = GetOperatorsForType(type.Value).FirstOrDefault(o => o.Operator == criteria.ComparisonType);
            if (match != null)
                return match.Label;
        }
        return criteria.ComparisonType.ToString().SplitOnCapitalLetters();
    }

    private async Task ToggleEnabledAsync(bool isEnabled)
    {
        if (_predefinedSearch == null)
            return;

        try
        {
            using var jim = JimFactory.Create();
            var core = await jim.Search.GetPredefinedSearchCoreAsync(_predefinedSearch.Id);
            if (core == null)
            {
                Snackbar.Add("Predefined search no longer exists.", Severity.Error);
                return;
            }

            core.IsEnabled = isEnabled;
            await jim.Search.UpdatePredefinedSearchAsync(core);
            _predefinedSearch.IsEnabled = isEnabled;
            Snackbar.Add($"Predefined search '{_predefinedSearch.Name}' {(isEnabled ? "enabled" : "disabled")}.", Severity.Success);
        }
        catch (InvalidOperationException ex)
        {
            Snackbar.Add($"Failed to update predefined search: {ex.Message}", Severity.Error);
        }
    }
}
