<MudText Class="mud-text-secondary">
    Each connector requires specific settings to connect to your environment.
    Complete the required fields below, then save your changes before importing the schema.
</MudText>

<MudForm @ref="_settingsForm" @bind-IsValid="@IsSettingsFormValid" @bind-Errors="@SettingsFormErrors">
    <PrefilledFormValidator />
    <MudExpansionPanels MultiExpansion="true" Elevation="0" Class="mt-5 jim-expansion-panel">
        @if (SettingCategories != null)
        {
            @for (var i = 0; i < SettingCategories.Count; i++)
            {
                var settingCategory = SettingCategories[i];
                var categoryKey = settingCategory.ToString();
                <MudExpansionPanel Expanded="@GetCategoryExpanded(categoryKey)"
                                   ExpandedChanged="@(expanded => OnCategoryExpandedChanged(categoryKey, expanded))">
                    <TitleContent>
                        <MudText Typo="Typo.subtitle1">@categoryKey</MudText>
                    </TitleContent>
                    <ChildContent>
                        @{
                            // settings whose RequiredWhen condition is not met are irrelevant; hide them entirely
                            var categorySettings = ConnectedSystem.SettingValues
                                .Where(sv => sv.Setting.Category == settingCategory)
                                .Where(sv => ConnectorSettingValidator.IsConditionMet(ConnectedSystem.SettingValues, sv.Setting))
                                .OrderBy(sv => sv.Setting.Id)
                                .ToList();
                            var headingCount = categorySettings.Count(sv => sv.Setting.Type == ConnectedSystemSettingType.Heading);
                            var headingsRendered = 0;
                            var j = 0;
                        }
                        @while (j < categorySettings.Count)
                        {
                            var settingValue = categorySettings[j];
                            var requiredGroup = settingValue.Setting.RequiredGroup;

                            if (!string.IsNullOrEmpty(requiredGroup))
                            {
                                // consecutive settings sharing a RequiredGroup render together: at least one of them must be supplied
                                var groupMembers = new List<ConnectedSystemSettingValue>();
                                while (j < categorySettings.Count && categorySettings[j].Setting.RequiredGroup == requiredGroup)
                                {
                                    groupMembers.Add(categorySettings[j]);
                                    j++;
                                }
                                var groupSpacingClass = j >= categorySettings.Count ? "pa-4" : "pa-4 mb-5";
                                var groupSatisfied = ConnectorSettingValidator.IsGroupSatisfied(ConnectedSystem.SettingValues, requiredGroup);
                                var groupCardinality = ConnectorSettingValidator.GetGroupCardinality(groupMembers);
                                var groupCaption = groupCardinality == ConnectorSettingRequiredGroupCardinality.ExactlyOne
                                    ? "Provide a value for exactly one of the following settings:"
                                    : "Provide a value for at least one of the following settings:";
                                <MudPaper Outlined="true" Class="@groupSpacingClass">
                                    <MudText Typo="Typo.h6">@requiredGroup</MudText>
                                    @if (groupSatisfied)
                                    {
                                        <MudText Typo="Typo.body2" Class="mud-text-secondary mb-4">@groupCaption</MudText>
                                    }
                                    else
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Error" Class="mb-4">@groupCaption</MudText>
                                    }
                                    @for (var k = 0; k < groupMembers.Count; k++)
                                    {
                                        <ConnectedSystemSettingField SettingValue="@groupMembers[k]"
                                                                     CssClass="@(k == groupMembers.Count - 1 ? "" : "mb-5")"
                                                                     Immediate="true"
                                                                     IsExportOnlyMode="@ConnectedSystem.IsExportOnlyMode()"
                                                                     ValueChanged="OnSettingValueChanged"
                                                                     FileSelected="OnFileSelectedAsync" />
                                    }
                                </MudPaper>
                            }
                            else
                            {
                                if (settingValue.Setting.Type == ConnectedSystemSettingType.Heading)
                                {
                                    // separate second-level setting headings from each other when a category has more than one
                                    if (headingsRendered > 0 && headingCount > 1)
                                    {
                                        <MudDivider Class="my-4" />
                                    }
                                    headingsRendered++;
                                }

                                <ConnectedSystemSettingField SettingValue="@settingValue"
                                                             CssClass="@(j == categorySettings.Count - 1 ? "" : "mb-5")"
                                                             IsRequired="@ConnectorSettingValidator.IsSettingRequired(ConnectedSystem.SettingValues, settingValue.Setting)"
                                                             Immediate="true"
                                                             IsExportOnlyMode="@ConnectedSystem.IsExportOnlyMode()"
                                                             ValueChanged="OnSettingValueChanged"
                                                             FileSelected="OnFileSelectedAsync" />
                                j++;
                            }
                        }
                    </ChildContent>
                </MudExpansionPanel>
            }
        }

        @if (ConnectedSystem.ConnectorDefinition is { SupportsExport: true, SupportsParallelExport: true })
        {
            <MudExpansionPanel Expanded="@GetCategoryExpanded("Export Performance")"
                               ExpandedChanged="@(expanded => OnCategoryExpandedChanged("Export Performance", expanded))">
                <TitleContent>
                    <MudText Typo="Typo.subtitle1">Export Performance</MudText>
                </TitleContent>
                <ChildContent>
                    <MudText Class="mud-text-secondary mb-5">
                        These settings control how JIM processes exports, independently of connector-specific settings above.
                    </MudText>
                    <MudTextField T="int?"
                                  Label="Max Export Parallelism"
                                  @bind-Value="ConnectedSystem.MaxExportParallelism"
                                  HelperText="Number of export batches to process concurrently (1 = sequential). Each parallel batch uses its own database connection and connector instance."
                                  InputType="InputType.Number"
                                  Variant="Variant.Outlined" />
                </ChildContent>
            </MudExpansionPanel>
        }
    </MudExpansionPanels>

    @if (SettingsFormCustomErrors.Count > 0)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-5">
            <MudText>There are issues with the settings:</MudText>
            <ul class="mt-5">
                @foreach (var error in SettingsFormCustomErrors)
                {
                    <li>@error.Key: @error.Value</li>
                }
            </ul>
        </MudAlert>
    }
</MudForm>
<MudButton Variant="Variant.Filled" Color="@(IsSettingsFormValid || !_settingsBeingSaved ? Color.Primary : Color.Default)" Disabled="@(!IsSettingsFormValid || !AreSettingGroupsSatisfied() || _settingsBeingSaved)" Class="mt-5" DropShadow="false" OnClick="HandleValidSettingsSubmitAsync">
    @if (_settingsBeingSaved)
    {
        <MudProgressCircular Class="ms-n1" Indeterminate="true" />
        <span class="ms-2">Processing</span>
    }
    else
    {
        <text>Save Settings</text>
    }
</MudButton>

@code {
    [Parameter, EditorRequired]
    public ConnectedSystem ConnectedSystem { get; set; } = null!;

    [Parameter, EditorRequired]
    public List<ConnectedSystemSettingCategory> SettingCategories { get; set; } = null!;

    [Parameter]
    public EventCallback OnConnectedSystemChanged { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private bool IsSettingsFormValid { get; set; }
    private string[] SettingsFormErrors { get; set; } = [];
    private Dictionary<string, string> SettingsFormCustomErrors { get; } = new();
    private bool _settingsBeingSaved;
    private MudForm? _settingsForm;

    /// <summary>
    /// Per-category (and Export Performance) expanded state for the settings accordion.
    /// Not persisted; defaults to expanded so settings remain visible without extra clicks.
    /// </summary>
    private readonly Dictionary<string, bool> _categoryExpandedStates = new();

    private bool GetCategoryExpanded(string categoryKey) => _categoryExpandedStates.GetValueOrDefault(categoryKey, true);

    private void OnCategoryExpandedChanged(string categoryKey, bool expanded) => _categoryExpandedStates[categoryKey] = expanded;

    private async Task HandleValidSettingsSubmitAsync()
    {
        using var jim = JimFactory.Create();
        _settingsBeingSaved = true;
        SettingsFormCustomErrors.Clear();

        StateHasChanged();
        await Task.Delay(1);

        var results = jim.ConnectedSystems.ValidateConnectedSystemSettings(ConnectedSystem);
        for (var i = 0; i < results.Count; i++)
        {
            var result = results[i];
            if (result.IsValid)
                continue;

            // indexer assignment (not .Add) so two results targeting the same setting cannot throw a duplicate-key exception
            switch (result.SettingValue)
            {
                case { Setting.Name: not null } when !string.IsNullOrEmpty(result.ErrorMessage):
                    SettingsFormCustomErrors[result.SettingValue.Setting.Name] = result.ErrorMessage;
                    break;
                case null when !string.IsNullOrEmpty(result.ErrorMessage):
                    SettingsFormCustomErrors[$"General issue {i + 1}"] = result.ErrorMessage;
                    break;
            }
        }

        if (SettingsFormCustomErrors.Any())
        {
            _settingsBeingSaved = false;
            return;
        }

        // offer an optional reason for the configuration change history once validation has passed;
        // cancelling aborts the save
        var (cancelled, changeReason) = await ChangeReasonDialog.ShowAsync(DialogService);
        if (cancelled)
        {
            _settingsBeingSaved = false;
            return;
        }

        var user = await Helpers.GetUserAsync(jim, AuthenticationStateTask);
        await jim.ConnectedSystems.UpdateConnectedSystemAsync(ConnectedSystem, user, changeReason);
        Snackbar.Add("Your setting changes have been saved.", Severity.Success);
        _settingsBeingSaved = false;

        await OnConnectedSystemChanged.InvokeAsync();
    }

    /// <summary>
    /// Determines whether every RequiredGroup across the Connected System's settings is satisfied: at least one value
    /// supplied for AtLeastOne groups, exactly one for ExactlyOne groups.
    /// Gates the save button alongside MudForm validity, as group constraints span multiple fields.
    /// </summary>
    private bool AreSettingGroupsSatisfied()
    {
        return ConnectedSystem.SettingValues
            .Select(sv => sv.Setting.RequiredGroup)
            .Where(g => !string.IsNullOrEmpty(g))
            .Distinct()
            .All(g => ConnectorSettingValidator.IsGroupSatisfied(ConnectedSystem.SettingValues, g!));
    }

    private void OnSettingValueChanged()
    {
        // no action needed; handling the child component's callback re-renders this component,
        // refreshing required-group feedback and the save button's enabled state
    }

    private async Task OnFileSelectedAsync()
    {
        if (_settingsForm != null)
        {
            await _settingsForm.ValidateAsync();
        }
    }
}
