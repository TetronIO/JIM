@using JIM.Models.Activities
@using JIM.Models.Core
@using JIM.Models.Staging
@using JIM.Utilities

<div class="outcome-node">
    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="2">
        <MudIcon Icon="@Helpers.GetOutcomeTypeIcon(Outcome.OutcomeType)"
                 Color="@Helpers.GetOutcomeTypeMudBlazorColor(Outcome.OutcomeType)"
                 Size="Size.Medium" />
        <div style="flex: 1; min-width: 0;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="flex-wrap">
                <MudText Typo="Typo.body1" Class="jim-text-emphasis">
                    @Helpers.GetOutcomeTypeDisplayName(Outcome.OutcomeType)
                </MudText>
                @if (HasInlineTargetDescription)
                {
                    @* Inline target entity shown on the same row as the outcome type (e.g., Projected → MVO name, Provisioned → CS name) *@
                    <MudText Typo="Typo.body1" Class="mud-text-secondary">@GetInlineSeparator()</MudText>
                    @if (IsProvisionedWithCsLink)
                    {
                        <MudLink Href="@GetProvisionedCsHref()" Typo="Typo.body1" Class="mud-text-secondary">
                            @Outcome.TargetEntityDescription
                        </MudLink>
                    }
                    else if (HasMvoLink)
                    {
                        <MudLink Href="@GetMvoHref(Outcome.TargetEntityId!.Value)"
                                 Typo="Typo.body1" Class="mud-text-secondary">
                            @Outcome.TargetEntityDescription
                        </MudLink>
                    }
                    else
                    {
                        <MudText Typo="Typo.body1" Class="mud-text-secondary">
                            @Outcome.TargetEntityDescription
                        </MudText>
                    }
                }
                @if (Outcome.DetailCount.HasValue)
                {
                    <MudChip T="string" Color="@Helpers.GetOutcomeTypeMudBlazorColor(Outcome.OutcomeType)"
                             Variant="Variant.Text" Size="Size.Medium">
                        @Outcome.DetailCount.Value @(Outcome.DetailCount.Value == 1 ? "attribute" : "attributes")
                    </MudChip>
                }
                @if (IsAttributeFlowWithChanges)
                {
                    <MudTooltip Text="@(_expanded ? "Hide attribute changes" : "Show attribute changes")">
                        <MudIconButton Icon="@(_expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                       Size="Size.Small" OnClick="ToggleExpand" />
                    </MudTooltip>
                }
                @if (IsPendingExportWithChanges)
                {
                    <MudTooltip Text="@(_expanded ? "Hide pending export detail" : "Show pending export detail")">
                        <MudIconButton Icon="@(_expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                       Size="Size.Small" OnClick="ToggleExpand" />
                    </MudTooltip>
                }
            </MudStack>
            @{
                var description = GetDescription();
            }
            @if (description != null)
            {
                @description
            }
            @if (!string.IsNullOrEmpty(Outcome.DetailMessage) && !IsProvisionedWithCsLink)
            {
                <MudText Typo="Typo.body1" Class="mud-text-secondary">
                    @Outcome.DetailMessage
                </MudText>
            }

        </div>
    </MudStack>

    @* Expandable attribute change detail for CsoAdded, CsoUpdated, and AttributeFlow nodes *@
    @if (_expanded && IsAttributeFlowWithChanges)
    {
        <div class="@($"mt-2{(Outcome.Children.Count > 0 ? " outcome-table-continuation" : "")}")">
            <AttributeChangeTable AttributeChanges="AttributeChanges"
                                   MvoAttributeChanges="MvoAttributeChanges" />
        </div>
    }

    @* Expandable attribute detail for PendingExportCreated nodes (from persisted CSO change snapshot) *@
    @if (_expanded && IsPendingExportWithChanges)
    {
        <div class="@($"mt-2{(Outcome.Children.Count > 0 ? " outcome-table-continuation" : "")}")">
            <AttributeChangeTable AttributeChanges="Outcome.ConnectedSystemObjectChange!.AttributeChanges.ToList()" />
        </div>
    }

    @if (Outcome.Children.Count > 0)
    {
        <div class="outcome-children">
            @foreach (var child in Outcome.Children.OrderBy(c => c.Ordinal))
            {
                <OutcomeTreeNode Outcome="child"
                                 AttributeChanges="AttributeChanges"
                                 MvoAttributeChanges="MvoAttributeChanges" />
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public ActivityRunProfileExecutionItemSyncOutcome Outcome { get; set; } = null!;

    /// <summary>
    /// Optional attribute changes from the RPEI's ConnectedSystemObjectChange,
    /// passed down from the OutcomeTree container.
    /// </summary>
    [Parameter]
    public List<ConnectedSystemObjectChangeAttribute>? AttributeChanges { get; set; }

    /// <summary>
    /// Optional MVO attribute changes from the RPEI's MetaverseObjectChange,
    /// passed down from the OutcomeTree container.
    /// </summary>
    [Parameter]
    public List<MetaverseObjectChangeAttribute>? MvoAttributeChanges { get; set; }

    private bool _expanded;

    private bool IsAttributeFlowWithChanges =>
        (Outcome.OutcomeType == ActivityRunProfileExecutionItemSyncOutcomeType.AttributeFlow
         || Outcome.OutcomeType == ActivityRunProfileExecutionItemSyncOutcomeType.CsoAdded
         || Outcome.OutcomeType == ActivityRunProfileExecutionItemSyncOutcomeType.CsoUpdated
         || Outcome.OutcomeType == ActivityRunProfileExecutionItemSyncOutcomeType.Exported
         || Outcome.OutcomeType == ActivityRunProfileExecutionItemSyncOutcomeType.Deprovisioned)
        && ((AttributeChanges != null && AttributeChanges.Count > 0)
            || (MvoAttributeChanges != null && MvoAttributeChanges.Count > 0));

    /// <summary>
    /// Whether this PendingExportCreated node has a persisted CSO change snapshot with attribute detail.
    /// </summary>
    private bool IsPendingExportWithChanges =>
        Outcome.OutcomeType == ActivityRunProfileExecutionItemSyncOutcomeType.PendingExportCreated
        && Outcome.ConnectedSystemObjectChange?.AttributeChanges.Count > 0;

    /// <summary>
    /// Outcome types that show their target entity inline on the title row
    /// rather than as a separate description line below.
    /// </summary>
    private bool HasInlineTargetDescription =>
        !string.IsNullOrEmpty(Outcome.TargetEntityDescription)
        && Outcome.OutcomeType is ActivityRunProfileExecutionItemSyncOutcomeType.Projected
            or ActivityRunProfileExecutionItemSyncOutcomeType.Joined
            or ActivityRunProfileExecutionItemSyncOutcomeType.Provisioned;

    /// <summary>
    /// Whether this Provisioned node has a connected system link available.
    /// The CS integer ID is stored in DetailMessage as a convention for Provisioned outcomes.
    /// </summary>
    private bool IsProvisionedWithCsLink =>
        Outcome.OutcomeType == ActivityRunProfileExecutionItemSyncOutcomeType.Provisioned
        && !string.IsNullOrEmpty(Outcome.DetailMessage)
        && int.TryParse(Outcome.DetailMessage, out _);

    /// <summary>
    /// Whether this outcome has an MVO link (Guid target entity ID that isn't empty).
    /// </summary>
    private bool HasMvoLink =>
        Outcome.TargetEntityId.HasValue && Outcome.TargetEntityId.Value != Guid.Empty;

    private string GetInlineSeparator() =>
        Outcome.OutcomeType == ActivityRunProfileExecutionItemSyncOutcomeType.Joined
            ? "\u2014 to"
            : "\u2014";

    private void ToggleExpand()
    {
        _expanded = !_expanded;
    }

    /// <summary>
    /// Builds a contextual description as a RenderFragment, using MudLink when a target entity link is available.
    /// Returns null when there's nothing to display.
    /// Outcome types rendered inline on the title row (Projected, Joined, Provisioned) are excluded here.
    /// </summary>
    private RenderFragment? GetDescription()
    {
        if (string.IsNullOrEmpty(Outcome.TargetEntityDescription))
            return null;

        return Outcome.OutcomeType switch
        {
            // Projected, Joined, and Provisioned show their target inline on the title row
            ActivityRunProfileExecutionItemSyncOutcomeType.Projected => null,
            ActivityRunProfileExecutionItemSyncOutcomeType.Joined => null,
            ActivityRunProfileExecutionItemSyncOutcomeType.Provisioned => null,
            // AttributeFlow child nodes don't need a separate MVO description line
            ActivityRunProfileExecutionItemSyncOutcomeType.AttributeFlow => null,
            ActivityRunProfileExecutionItemSyncOutcomeType.Disconnected
                => RenderMvoDescription("from MVO: "),
            ActivityRunProfileExecutionItemSyncOutcomeType.MvoDeleted
                => RenderMvoDescription("MVO deleted: "),
            // For connected system targets (pending exports, exports), just show the name
            _ => RenderPlainDescription()
        };
    }

    private RenderFragment RenderMvoDescription(string prefix) => __builder =>
    {
        <MudText Typo="Typo.body1" Class="mud-text-secondary">
            @prefix
            @if (Outcome.TargetEntityId.HasValue && Outcome.TargetEntityId.Value != Guid.Empty)
            {
                <MudLink Href="@GetMvoHref(Outcome.TargetEntityId.Value)">@Outcome.TargetEntityDescription</MudLink>
            }
            else
            {
                @Outcome.TargetEntityDescription
            }
        </MudText>
    };

    private RenderFragment RenderPlainDescription() => __builder =>
    {
        <MudText Typo="Typo.body1" Class="mud-text-secondary">
            @Outcome.TargetEntityDescription
        </MudText>
    };

    /// <summary>
    /// Builds the MVO href. Since we don't have the type plural name on the outcome,
    /// we use a search-based redirect path.
    /// </summary>
    private static string GetMvoHref(Guid mvoId) => $"/identity/search/{mvoId}";

    /// <summary>
    /// Builds the connected system href for Provisioned outcomes.
    /// The CS integer ID is stored in DetailMessage by convention.
    /// </summary>
    private string GetProvisionedCsHref() => $"/admin/connected-systems/{Outcome.DetailMessage}";

}
