@using JIM.Models.Activities
@using JIM.Models.Staging
@using JIM.Models.Transactional
@using JIM.Utilities

<div class="outcome-node">
    <MudStack Row="true" AlignItems="AlignItems.Start" Spacing="2">
        <MudIcon Icon="@Helpers.GetOutcomeTypeIcon(Outcome.OutcomeType)"
                 Color="@Helpers.GetOutcomeTypeMudBlazorColor(Outcome.OutcomeType)"
                 Size="Size.Medium" Class="mt-1" />
        <div style="flex: 1; min-width: 0;">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="flex-wrap">
                <MudText Typo="Typo.body1" Class="jim-text-emphasis">
                    @Helpers.GetOutcomeTypeDisplayName(Outcome.OutcomeType)
                </MudText>
                @if (Outcome.DetailCount.HasValue)
                {
                    <MudChip T="string" Color="@Helpers.GetOutcomeTypeMudBlazorColor(Outcome.OutcomeType)"
                             Variant="Variant.Text" Size="Size.Medium">
                        @Outcome.DetailCount.Value @(Outcome.DetailCount.Value == 1 ? "attribute" : "attributes")
                    </MudChip>
                }
                @if (IsAttributeFlowWithChanges)
                {
                    <MudTooltip Text="@(_expanded ? "Hide attribute changes" : "Show attribute changes")">
                        <MudIconButton Icon="@(_expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                       Size="Size.Small" OnClick="ToggleExpand" />
                    </MudTooltip>
                }
                @if (IsPendingExportExpandable)
                {
                    <MudTooltip Text="@(_expanded ? "Hide pending export detail" : "Show pending export detail")">
                        <MudIconButton Icon="@(_expanded ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                       Size="Size.Small" OnClick="TogglePendingExportExpandAsync" />
                    </MudTooltip>
                }
            </MudStack>
            @{
                var description = GetDescription();
            }
            @if (description != null)
            {
                @description
            }
            @if (!string.IsNullOrEmpty(Outcome.DetailMessage))
            {
                <MudText Typo="Typo.body1" Class="mud-text-secondary">
                    @Outcome.DetailMessage
                </MudText>
            }

            @* Expandable attribute change detail for AttributeFlow nodes *@
            @if (_expanded && IsAttributeFlowWithChanges)
            {
                <div class="mt-2">
                    <MudSimpleTable Dense="true" Hover="true" Elevation="0" Style="background: transparent;">
                        <tbody>
                            @foreach (var change in AttributeChanges!.OrderBy(c => c.Attribute.Name))
                            {
                                @foreach (var vc in change.ValueChanges)
                                {
                                    <tr>
                                        <td style="padding: 4px 12px 4px 0; border: none; vertical-align: top; white-space: nowrap;">
                                            <MudText Class="mud-text-secondary">@change.Attribute.Name</MudText>
                                        </td>
                                        <td style="padding: 4px 8px 4px 0; border: none; vertical-align: top; white-space: nowrap;">
                                            <MudChip T="string" Variant="Variant.Text"
                                                     Color="@Helpers.GetMudBlazorColorForValueChangeType(vc.ValueChangeType)"
                                                     Size="Size.Small" Class="ml-0">
                                                @vc.ValueChangeType
                                            </MudChip>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </MudSimpleTable>
                </div>
            }

            @* Expandable attribute detail for PendingExportCreated nodes *@
            @if (_expanded && IsPendingExportExpandable)
            {
                <div class="mt-2">
                    @if (_pendingExportLoading)
                    {
                        <MudProgressLinear Indeterminate="true" />
                    }
                    else if (_pendingExport != null && _pendingExport.AttributeValueChanges.Count > 0)
                    {
                        <MudSimpleTable Dense="true" Hover="true" Elevation="0" Style="background: transparent;">
                            <tbody>
                                @foreach (var change in _pendingExport.AttributeValueChanges.OrderBy(c => c.Attribute.Name))
                                {
                                    <tr>
                                        <td style="padding: 4px 12px 4px 0; border: none; vertical-align: top; white-space: nowrap;">
                                            <MudText Class="mud-text-secondary">@change.Attribute.Name</MudText>
                                        </td>
                                        <td style="padding: 4px 8px 4px 0; border: none; vertical-align: top; white-space: nowrap;">
                                            <MudChip T="string" Variant="Variant.Text"
                                                     Color="@GetPendingExportChangeColor(change.ChangeType)"
                                                     Size="Size.Small" Class="ml-0">
                                                @change.ChangeType
                                            </MudChip>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </MudSimpleTable>
                    }
                    else if (_pendingExport != null)
                    {
                        <MudText Class="mud-text-secondary">No attribute changes.</MudText>
                    }
                    else
                    {
                        <MudText Class="mud-text-secondary">Pending export detail not available.</MudText>
                    }
                </div>
            }
        </div>
    </MudStack>

    @if (Outcome.Children.Count > 0)
    {
        <div class="outcome-children">
            @foreach (var child in Outcome.Children.OrderBy(c => c.Ordinal))
            {
                <OutcomeTreeNode Outcome="child"
                                 AttributeChanges="AttributeChanges"
                                 OnLoadPendingExport="OnLoadPendingExport" />
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public ActivityRunProfileExecutionItemSyncOutcome Outcome { get; set; } = null!;

    /// <summary>
    /// Optional attribute changes from the RPEI's ConnectedSystemObjectChange,
    /// passed down from the OutcomeTree container.
    /// </summary>
    [Parameter]
    public List<ConnectedSystemObjectChangeAttribute>? AttributeChanges { get; set; }

    /// <summary>
    /// Callback for loading pending export data on demand when a PendingExportCreated node is expanded.
    /// </summary>
    [Parameter]
    public Func<Guid, Task<PendingExport?>>? OnLoadPendingExport { get; set; }

    private bool _expanded;
    private PendingExport? _pendingExport;
    private bool _pendingExportLoading;

    private bool IsAttributeFlowWithChanges =>
        (Outcome.OutcomeType == ActivityRunProfileExecutionItemSyncOutcomeType.AttributeFlow
         || Outcome.OutcomeType == ActivityRunProfileExecutionItemSyncOutcomeType.CsoAdded
         || Outcome.OutcomeType == ActivityRunProfileExecutionItemSyncOutcomeType.CsoUpdated)
        && AttributeChanges != null
        && AttributeChanges.Count > 0;

    private bool IsPendingExportExpandable =>
        Outcome.OutcomeType == ActivityRunProfileExecutionItemSyncOutcomeType.PendingExportCreated
        && Outcome.TargetEntityId.HasValue
        && OnLoadPendingExport != null;

    private void ToggleExpand()
    {
        _expanded = !_expanded;
    }

    private async Task TogglePendingExportExpandAsync()
    {
        _expanded = !_expanded;
        if (_expanded && _pendingExport == null && !_pendingExportLoading)
        {
            _pendingExportLoading = true;
            _pendingExport = await OnLoadPendingExport!(Outcome.TargetEntityId!.Value);
            _pendingExportLoading = false;
        }
    }

    /// <summary>
    /// Builds a contextual description as a RenderFragment, using MudLink when a target entity link is available.
    /// Returns null when there's nothing to display.
    /// </summary>
    private RenderFragment? GetDescription()
    {
        if (string.IsNullOrEmpty(Outcome.TargetEntityDescription))
            return null;

        return Outcome.OutcomeType switch
        {
            ActivityRunProfileExecutionItemSyncOutcomeType.Projected
                => RenderMvoDescription("MVO created: "),
            ActivityRunProfileExecutionItemSyncOutcomeType.Joined
                => RenderMvoDescription("to MVO: "),
            ActivityRunProfileExecutionItemSyncOutcomeType.AttributeFlow
                => RenderMvoDescription("to MVO: "),
            ActivityRunProfileExecutionItemSyncOutcomeType.Disconnected
                => RenderMvoDescription("from MVO: "),
            ActivityRunProfileExecutionItemSyncOutcomeType.MvoDeleted
                => RenderMvoDescription("MVO deleted: "),
            // For connected system targets (pending exports, exports), just show the name
            _ => RenderPlainDescription()
        };
    }

    private RenderFragment RenderMvoDescription(string prefix) => __builder =>
    {
        <MudText Typo="Typo.body1" Class="mud-text-secondary">
            @prefix
            @if (Outcome.TargetEntityId.HasValue && Outcome.TargetEntityId.Value != Guid.Empty)
            {
                <MudLink Href="@GetMvoHref(Outcome.TargetEntityId.Value)">@Outcome.TargetEntityDescription</MudLink>
            }
            else
            {
                @Outcome.TargetEntityDescription
            }
        </MudText>
    };

    private RenderFragment RenderPlainDescription() => __builder =>
    {
        <MudText Typo="Typo.body1" Class="mud-text-secondary">
            @Outcome.TargetEntityDescription
        </MudText>
    };

    /// <summary>
    /// Builds the MVO href. Since we don't have the type plural name on the outcome,
    /// we use a search-based redirect path.
    /// </summary>
    private static string GetMvoHref(Guid mvoId) => $"/identity/search/{mvoId}";

    private static Color GetPendingExportChangeColor(PendingExportAttributeChangeType changeType) =>
        changeType switch
        {
            PendingExportAttributeChangeType.Add => Color.Success,
            PendingExportAttributeChangeType.Update => Color.Info,
            PendingExportAttributeChangeType.Remove => Color.Warning,
            PendingExportAttributeChangeType.RemoveAll => Color.Error,
            _ => Color.Default
        };
}
