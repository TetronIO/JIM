@* Recursively renders one node of a configuration diff tree, git-style: additions green, removals red,
   a modified scalar shows its old value (red) then its new value (green), and a changed secret is shown
   amber with its value hidden. Unchanged nodes (scalars and containers alike) render nothing, so the diff
   shows only what actually changed. A changed container renders a muted context header with just its
   changed descendants beneath it. *@

@if (Node.NodeType == ConfigurationSnapshotNodeType.Scalar)
{
    @if (Node.ChangeType == ConfigurationDiffChangeType.Modified && !Node.IsSecret)
    {
        <div style="@_indent">
            <MudText Typo="Typo.body2" Color="Color.Error" Style="@MonospaceStyle">- @_label: @Node.OldValue</MudText>
        </div>
        <div style="@_indent">
            <MudText Typo="Typo.body2" Color="Color.Success" Style="@MonospaceStyle">+ @_label: @Node.NewValue</MudText>
        </div>
    }
    else if (_scalarLine != null)
    {
        <div style="@_indent">
            <MudText Typo="Typo.body2" Color="@_scalarColour" Style="@MonospaceStyle">@_scalarLine</MudText>
        </div>
    }
}
else
{
    @* Object or Collection node. Unchanged containers render nothing; only changed branches are shown. *@
    @if (Node.ChangeType != ConfigurationDiffChangeType.Unchanged)
    {
        <div style="@_indent">
            <MudText Typo="Typo.body2" Color="@_containerColour" Class="@_containerClass" Style="@MonospaceStyle">@_containerHeader</MudText>
        </div>
        @if (Node.Children != null)
        {
            @foreach (var child in Node.Children)
            {
                <ConfigurationChangeDiffNode Node="child" Depth="Depth + 1" />
            }
        }
    }
}

@code {
    /// <summary>The diff node to render.</summary>
    [Parameter, EditorRequired]
    public ConfigurationDiffNode Node { get; set; } = null!;

    /// <summary>Nesting depth, used for indentation; 0 for a top-level section.</summary>
    [Parameter]
    public int Depth { get; set; }

    private const string MonospaceStyle = "font-family: monospace; white-space: pre-wrap;";

    private string _label = string.Empty;
    private string _indent = string.Empty;

    // Pre-computed presentation for the single-line cases (added/removed scalar, or a changed secret).
    private string? _scalarLine;
    private Color _scalarColour = Color.Default;

    // Pre-computed presentation for a container header (object/collection that changed).
    private string _containerHeader = string.Empty;
    private Color _containerColour = Color.Default;
    private string? _containerClass;

    protected override void OnParametersSet()
    {
        _label = string.IsNullOrEmpty(Node.Label) ? Node.Key : Node.Label;
        _indent = $"padding-left: {Depth * 24}px;";
        _scalarLine = null;
        _containerClass = null;

        if (Node.NodeType == ConfigurationSnapshotNodeType.Scalar)
        {
            switch (Node.ChangeType)
            {
                case ConfigurationDiffChangeType.Added:
                    _scalarLine = Node.IsSecret ? $"+ {_label}  (secret set)" : $"+ {_label}: {Node.NewValue}";
                    _scalarColour = Color.Success;
                    break;
                case ConfigurationDiffChangeType.Removed:
                    _scalarLine = Node.IsSecret ? $"- {_label}  (secret removed)" : $"- {_label}: {Node.OldValue}";
                    _scalarColour = Color.Error;
                    break;
                case ConfigurationDiffChangeType.Modified when Node.IsSecret:
                    _scalarLine = $"~ {_label}  (secret changed; value hidden)";
                    _scalarColour = Color.Warning;
                    break;
                // A modified non-secret scalar is rendered as two lines in markup; an unchanged scalar renders nothing.
            }
        }
        else
        {
            switch (Node.ChangeType)
            {
                case ConfigurationDiffChangeType.Added:
                    _containerHeader = $"+ {_label}";
                    _containerColour = Color.Success;
                    break;
                case ConfigurationDiffChangeType.Removed:
                    _containerHeader = $"- {_label}";
                    _containerColour = Color.Error;
                    break;
                default:
                    // Modified: a muted context header, with only the changed descendants rendered beneath it.
                    _containerHeader = _label;
                    _containerColour = Color.Default;
                    _containerClass = "mud-text-secondary";
                    break;
            }
        }
    }
}
