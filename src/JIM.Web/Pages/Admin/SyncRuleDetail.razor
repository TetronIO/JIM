@page "/admin/sync-rules/new"
@page "/admin/sync-rules/{Id:int}"
@attribute [Authorize(Roles = "Administrator")]
@using JIM.Models.Activities
@using JIM.Models.Core
@using JIM.Models.Logic
@using JIM.Models.Staging.DTOs
@using JIM.Models.Utility
@using JIM.Web.Pages.Admin.Components
@using JIM.Application
@inject IJimApplicationFactory JimFactory
@inject NavigationManager NavManager
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@implements IDisposable

@* Copyright (c) Tetron Limited. All rights reserved. *@
@* Licensed under the Tetron Commercial License. See LICENSE file in the project root. *@

<PageTitle>Synchronisation Rule: @_syncRuleNameOrCreate</PageTitle>
<MudText Typo="Typo.h4"><MudIcon Icon="@Icons.Material.Filled.Sync" Size="Size.Large" Class="mr-2 mb-1" Style="vertical-align: middle;" /><span>Synchronisation Rule:</span> <span class="mud-primary-text">@_syncRuleNameOrCreate</span></MudText>
<div class="d-flex justify-space-between align-center">
    <MudBreadcrumbs Items="_breadcrumbs" Class="ps-0"></MudBreadcrumbs>
    @if (_syncRule is { Id: > 0 })
    {
        <AuditInfo Entity="@_syncRule" />
    }
</div>

@if (_isLoading)
{
    <div class="d-flex flex-column align-center justify-center mt-16">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.body2" Class="mt-4 mud-text-secondary">Loading Synchronisation Rule...</MudText>
    </div>
}
else if (_syncRule != null)
{
    <NavigableMudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="false" TabPanelsClass="pt-5" Class="mt-2" Outlined="true"
                      @bind-ActivePanelIndex="_activeTabIndex">

        <MudTabPanel Text="Details">
            <SyncRuleDetailsTab SyncRule="_syncRule"
                                ConnectedSystemHeaders="_connectedSystemHeaders"
                                MetaverseObjectTypes="_metaverseObjectTypes"
                                OnChanged="OnChildChanged" />
        </MudTabPanel>

        <MudTabPanel Text="Matching">
            <SyncRuleMatchingTab SyncRule="_syncRule" OnChanged="OnChildChanged" />
        </MudTabPanel>

        <MudTabPanel Text="Scope">
            <SyncRuleScopeTab SyncRule="_syncRule" OnChanged="OnChildChanged" />
        </MudTabPanel>

        <MudTabPanel Text="Attribute Flow">
            <SyncRuleAttributeFlowTab SyncRule="_syncRule" OnChanged="OnChildChanged" />
        </MudTabPanel>

        @if (_syncRule.Id > 0)
        {
            <MudTabPanel Text="Changes" BadgeData="@(_changeCount > 0 ? _changeCount.ToString("N0") : null)" BadgeColor="Color.Primary">
                <ConfigurationChangesTab TargetType="ActivityTargetType.SyncRule" ObjectId="_syncRule.Id" ObjectTypeLabel="Synchronisation Rule" />
            </MudTabPanel>
        }

        @if (_syncRule.Id > 0)
        {
            <MudTabPanel Text="Danger Zone" Icon="@Icons.Material.Filled.Warning" BadgeColor="Color.Error" ID="@("danger-zone")">
                <MudPaper Class="pa-4 jim-paper-danger-zone" Outlined="false">
                    <MudText Typo="Typo.h5" Class="mb-3">Danger Zone</MudText>
                    <MudText Class="mud-text-secondary mb-4">
                        Deleting this Synchronisation Rule is permanent and cannot be undone. All configuration and Attribute Flow
                        mappings will be lost.
                    </MudText>
                    <MudButton Variant="Variant.Filled" StartIcon="@Icons.Material.Filled.Delete" OnClick="HandleDeleteSyncRuleAsync"
                        DropShadow="false" Color="Color.Error">Delete Synchronisation Rule</MudButton>
                </MudPaper>
            </MudTabPanel>
        }

    </NavigableMudTabs>

    @* Save bar - applies to the whole rule from any editing tab, but not the read-only Changes or Danger Zone tabs *@
    @if (!IsReadOnlyTabActive)
    {
    <div class="mt-6">
        @if (_syncRule.Validate().Count > 0)
        {
            <MudAlert Severity="Severity.Warning" Variant="Variant.Outlined" NoIcon="true" Class="mb-4">
                <MudText Class="mb-3">There are issues:</MudText>
                @foreach (var item in _syncRule.Validate())
                {
                    <div class="d-flex align-center mb-2">
                        <MudIcon Class="mr-2" Color="@(item.Level == ValidityStatusItemLevel.Warning ? Color.Warning : Color.Error)"
                            Icon="@(item.Level == ValidityStatusItemLevel.Warning ? @Icons.Material.Filled.Warning : @Icons.Material.Filled.Error)" />
                        <MudText>@item.Message</MudText>
                    </div>
                }
            </MudAlert>
        }

        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="HandleCreateOrUpdateSyncRuleAsync"
            Disabled="!_syncRule.IsValid()" DropShadow="false">@(_syncRule.Id == 0 ? "Create" : "Update") Synchronisation Rule
        </MudButton>
    </div>
    }
}

@code {
    [Parameter]
    public int? Id { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState>? AuthenticationStateTask { get; set; }

    private string _syncRuleNameOrCreate = "New";
    private List<BreadcrumbItem> _breadcrumbs = null!;
    private SyncRule? _syncRule;
    private bool _isLoading = true;
    private List<ConnectedSystemHeader>? _connectedSystemHeaders;
    private List<MetaverseObjectType>? _metaverseObjectTypes;
    private bool _loaded;
    private int? _loadedId;
    private int _activeTabIndex;
    private int _changeCount;

    // Details, Matching, Scope, Attribute Flow occupy indexes 0-3. For an existing rule, Changes (4) and Danger
    // Zone (5) follow; both are read-only views, so the editing save bar is hidden when either is active.
    private const int ChangesTabIndex = 4;
    private bool IsReadOnlyTabActive => _syncRule is { Id: > 0 } && _activeTabIndex >= ChangesTabIndex;

    // A single JimApplication (and its DbContext) is held for the whole edit session. The rule is loaded
    // change-tracked and every tab mutates that tracked graph, so the final save lets EF Core diff and
    // persist the changes. A fresh context per handler would leave the rule detached at save time and the
    // update would silently persist nothing (e.g. toggling Enabled was lost this way).
    private JimApplication? _jim;

    // Both /admin/sync-rules/new and /admin/sync-rules/{id} resolve to this component, so creating a rule and
    // navigating from /new to /{id} reuses the instance (OnInitializedAsync does not run again). Load from
    // OnParametersSetAsync keyed on the route id so the page re-loads cleanly into edit mode after a create.
    protected override async Task OnParametersSetAsync()
    {
        if (_loaded && _loadedId == Id)
            return;

        _loaded = true;
        _loadedId = Id;
        _isLoading = true;
        await LoadSyncRuleAsync();
        _isLoading = false;
    }

    private async Task LoadSyncRuleAsync()
    {
        // Start a fresh context for this (re)load and hold it for the edit session; dispose any prior one
        // (e.g. the context used while creating, before navigating to the new rule's edit URL).
        _jim?.Dispose();
        _jim = JimFactory.Create();

        _breadcrumbs =
        [
            new BreadcrumbItem("Home", href: "/", icon: Icons.Material.Filled.Home),
            new BreadcrumbItem("Administration", href: "/admin"),
            new BreadcrumbItem("Synchronisation Rules", href: "/admin/sync-rules/")
        ];

        if (Id != null)
        {
            // edit an existing Synchronisation Rule - loaded change-tracked so edits persist on save
            _syncRule = await _jim.ConnectedSystems.GetSyncRuleAsync(Id.Value);
            if (_syncRule == null)
            {
                // Synchronisation Rule not found, redirect to index page
                _isLoading = false;
                NavManager.NavigateTo("../");
                return;
            }

            _syncRuleNameOrCreate = _syncRule.Name;
            _breadcrumbs.Add(new BreadcrumbItem(_syncRule.Name, href: null, disabled: true));

            // lightweight count for the Changes tab badge (one row fetched; TotalResults only)
            _changeCount = (await _jim.ChangeHistory.GetConfigurationChangeHistoryAsync(ActivityTargetType.SyncRule, _syncRule.Id, 1, 1)).TotalResults;
        }
        else
        {
            // create a new Synchronisation Rule
            _syncRule = new SyncRule();
            _syncRuleNameOrCreate = "New";
            _breadcrumbs.Add(new BreadcrumbItem("New", href: null, disabled: true));
            _connectedSystemHeaders = await _jim.ConnectedSystems.GetConnectedSystemHeadersAsync();
            _metaverseObjectTypes = await _jim.Metaverse.GetMetaverseObjectTypesAsync(true);
        }
    }

    private void OnChildChanged()
    {
        // a tab mutated the shared Synchronisation Rule; re-render so the save bar's validation and
        // enabled state stay in sync with the latest edits.
        StateHasChanged();
    }

    private async Task HandleCreateOrUpdateSyncRuleAsync()
    {
        if (_syncRule == null || _jim == null)
            return;

        // are we transitioning from new to existing?
        var isSyncRuleNew = _syncRule.Id == 0;

        // offer an optional reason for the configuration change history; cancelling aborts the save
        var (cancelled, changeReason) = await ChangeReasonDialog.ShowAsync(DialogService, isSyncRuleNew ? "Create" : "Update");
        if (cancelled)
            return;

        // save on the SAME context the rule was loaded on, so EF Core's change tracker sees the edits
        var user = await Helpers.GetUserAsync(_jim, AuthenticationStateTask);
        var wasSuccessful = await _jim.ConnectedSystems.CreateOrUpdateSyncRuleAsync(_syncRule, user, changeReason: changeReason);
        switch (wasSuccessful)
        {
            // send the user to the existing-sync-rule view.
            // this helps ensure links are good to be shared/bookmarked, etc.
            // the snackbar is enqueued before navigating; ISnackbar is circuit-scoped and the provider
            // lives in the layout, so the message survives the soft navigation and shows on the edit page.
            case true when isSyncRuleNew:
                Snackbar.Add("Synchronisation Rule created.", Severity.Success);
                NavManager.NavigateTo($"/admin/sync-rules/{_syncRule.Id}");
                break;
            case true:
                Snackbar.Add("Changes saved.", Severity.Success);
                break;
            case false:
                Snackbar.Add("There was a problem saving your changes. Please check the details and try again.", Severity.Error);
                break;
        }
    }

    private async Task HandleDeleteSyncRuleAsync()
    {
        if (_syncRule == null || _jim == null)
            return;

        var confirmationResult = await DialogService.ShowMessageBoxAsync("Warning", "Are you sure you want to delete this Synchronisation Rule?", yesText: "Delete!", cancelText: "Cancel");
        if (confirmationResult.HasValue && confirmationResult.Value)
        {
            // offer an optional reason for the configuration change history; cancelling aborts the delete
            var (cancelled, changeReason) = await ChangeReasonDialog.ShowAsync(DialogService, "Delete");
            if (cancelled)
                return;

            // attribute the operation to the signed-in user; use the edit session's context
            var user = await Helpers.GetUserAsync(_jim, AuthenticationStateTask);
            await _jim.ConnectedSystems.DeleteSyncRuleAsync(_syncRule, user, changeReason);
            NavManager.NavigateTo("/admin/sync-rules");
        }
    }

    public void Dispose()
    {
        _jim?.Dispose();
    }
}
