@* Inline, searchable, server-paged table of a single CSO attribute's values. Used directly in the
   attributes table's value cell for multi-valued attributes whose value count exceeds the inline cap,
   so all values are browsable in place without a dialog. *@

@if (_isReferenceAttribute)
{
    <MudTable @ref="_table" T="ConnectedSystemObjectAttributeValue"
              ServerData="ServerReloadAsync"
              Dense="@Dense" Hover="true" Elevation="0" Outlined="true"
              Class="jim-mva-dialog-table"
              Loading="@_loading" LoadingProgressColor="Color.Primary">
        <ToolBarContent>
            <MudTextField T="string" Value="@_searchText"
                          ValueChanged="@OnSearch"
                          Placeholder="@($"Search {AttributeName.ToLower()}...")"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" DebounceInterval="300"
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Display Name</MudTh>
            <MudTh>Type</MudTh>
            <MudTh>Secondary ID</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Display Name">
                @if (context.ReferenceValue != null)
                {
                    <MudLink Href="@Utilities.GetConnectedSystemObjectHref(context.ReferenceValue)">
                        @context.ReferenceValue.DisplayNameOrId
                    </MudLink>
                }
                else if (context.UnresolvedReferenceValue != null)
                {
                    <span class="jim-attr-unresolved">
                        <MudIcon Icon="@Icons.Material.Filled.LinkOff" Class="mr-1" />
                        <span class="mud-text-secondary">@context.UnresolvedReferenceValue</span>
                    </span>
                }
                else
                {
                    @(context.ToStringNoName())
                }
            </MudTd>
            <MudTd DataLabel="Type">
                @if (context.ReferenceValue != null)
                {
                    @context.ReferenceValue.Type.Name
                }
            </MudTd>
            <MudTd DataLabel="Secondary ID">
                @if (context.ReferenceValue?.SecondaryExternalIdAttributeValue != null)
                {
                    <span class="mud-text-secondary">
                        @context.ReferenceValue.SecondaryExternalIdAttributeValue.ToStringNoName()
                    </span>
                }
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}
else
{
    <MudTable @ref="_table" T="ConnectedSystemObjectAttributeValue"
              ServerData="ServerReloadAsync"
              Dense="@Dense" Hover="true" Elevation="0" Outlined="true"
              Class="jim-mva-dialog-table"
              Loading="@_loading" LoadingProgressColor="Color.Primary">
        <ToolBarContent>
            <MudTextField T="string" Value="@_searchText"
                          ValueChanged="@OnSearch"
                          Placeholder="@($"Search {AttributeName.ToLower()}...")"
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Search"
                          Immediate="true" DebounceInterval="300"
                          Variant="Variant.Outlined" Margin="Margin.Dense" />
        </ToolBarContent>
        <HeaderContent>
            <MudTh>Value</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="Value">
                <CsoAttributeValue Value="@context" />
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}

@code {
    /// <summary>
    /// The name of the attribute whose values are being paged.
    /// </summary>
    [Parameter]
    public string AttributeName { get; set; } = string.Empty;

    /// <summary>
    /// The owning Connected System Object's ID.
    /// </summary>
    [Parameter]
    public Guid ConnectedSystemObjectId { get; set; }

    /// <summary>
    /// Whether this attribute holds reference values (drives the multi-column reference layout).
    /// </summary>
    [Parameter]
    public bool IsReferenceAttribute { get; set; }

    /// <summary>
    /// Whether to render compact rows, driven by the host page's density toggle.
    /// </summary>
    [Parameter]
    public bool Dense { get; set; }

    private MudTable<ConnectedSystemObjectAttributeValue>? _table;
    private string _searchText = string.Empty;
    private bool _isReferenceAttribute;
    private bool _loading;
    private string? _loadedAttributeName;

    protected override void OnParametersSet()
    {
        _isReferenceAttribute = IsReferenceAttribute;

        // The host attributes table is sortable; a sort reorders rows and may hand this instance a
        // different attribute. Reset search and reload so the table reflects the new attribute.
        if (_loadedAttributeName != null && _loadedAttributeName != AttributeName)
        {
            _searchText = string.Empty;
            _table?.ReloadServerData();
        }

        _loadedAttributeName = AttributeName;
    }

    private async Task<TableData<ConnectedSystemObjectAttributeValue>> ServerReloadAsync(
        TableState state, CancellationToken token)
    {
        _loading = true;

        try
        {
            var page = state.Page + 1; // MudBlazor is 0-indexed
            var pageSize = state.PageSize;
            var searchText = string.IsNullOrWhiteSpace(_searchText) ? null : _searchText;

            using var jim = JimFactory.Create();
            var result = await jim.ConnectedSystems.GetAttributeValuesPagedAsync(
                ConnectedSystemObjectId, AttributeName, page, pageSize, searchText);

            return new TableData<ConnectedSystemObjectAttributeValue>
            {
                Items = result.Results,
                TotalItems = result.TotalResults
            };
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnSearch(string text)
    {
        _searchText = text;
        _table?.ReloadServerData();
    }
}
