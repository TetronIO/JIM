@inherits LayoutComponentBase
@implements IDisposable
@inject IJSRuntime JSRuntime
@inject IUserPreferenceService PreferenceService
@inject JIM.Web.Models.ThemeSettings ThemeSettings
@inject NavigationManager NavigationManager
@inject IJimApplicationFactory JimFactory

@* Copyright (c) Tetron Limited. All rights reserved. *@
@* Licensed under the Tetron Commercial License. See LICENSE file in the project root. *@
<MudThemeProvider @bind-IsDarkMode="@IsDarkMode" Theme="_theme" @ref="@_mudThemeProvider" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

@if (!string.IsNullOrEmpty(_serviceName))
{
    <PageTitle>JIM - @_serviceName</PageTitle>
}
else
{
    <PageTitle>JIM</PageTitle>
}

<MudLayout>

    @if (!string.IsNullOrEmpty(_serviceName))
    {
        <div class="jim-instance-bar">
            <span class="jim-title-accent">@_serviceName</span>
        </div>
    }

    <MudDrawerContainer Class="mud-height-full" Style="@(!string.IsNullOrEmpty(_serviceName) ? "padding-top: var(--jim-instance-bar-height)" : null)">
        <MudDrawer @bind-Open="@IsDrawerOpen" Elevation="0" Variant="@DrawerVariant.Mini" Overlay="false"
                   Class="@($"jim-drawer{(!string.IsNullOrEmpty(_serviceName) ? " jim-drawer-with-bar" : "")}")"
                   @onmouseenter="@OnDrawerMouseEnter" @onmouseleave="@OnDrawerMouseLeave">

            <div class="jim-drawer-logo d-flex align-center">
                @if (!IsDrawerOpen && !string.IsNullOrEmpty(_serviceName))
                {
                    <MudTooltip Text="@_serviceName" Arrow="true" Placement="Placement.Right">
                        <MudImage Src="/images/jim-logo.png" Width="28" Class="mt-4 ms-4 mb-3" Alt="JIM Logo"></MudImage>
                    </MudTooltip>
                }
                else
                {
                    <MudImage Src="/images/jim-logo.png" Width="28" Class="mt-4 ms-4 mb-3" Alt="JIM Logo"></MudImage>
                }
                @if (IsDrawerOpen)
                {
                    <MudText Class="ms-2 jim-drawer-logo-text">JIM</MudText>
                    <MudTooltip Text="@(IsDrawerPinned ? "Collapse sidebar" : "Pin sidebar open")" Arrow="true" Placement="Placement.Top">
                        <MudIconButton Icon="@Icons.Material.Filled.MenuOpen"
                                       Size="Size.Small"
                                       OnClick="ToggleDrawerPinned"
                                       Class="@($"jim-drawer-toggle{(IsDrawerPinned ? "" : " jim-drawer-toggle-collapsed")}")"
                                       aria-label="@(IsDrawerPinned ? "Collapse sidebar" : "Pin sidebar open")" />
                    </MudTooltip>
                }
            </div>

            <NavMenu DrawerOpen="@IsDrawerOpen" />

            <div class="jim-drawer-footer">
                <DrawerUserMenu DrawerOpen="@IsDrawerOpen"
                                @bind-IsDarkMode="@IsDarkMode" />
            </div>


        </MudDrawer>

        <MudMainContent>
            <CascadingValue Value="this" IsFixed="true">
                <MudContainer MaxWidth="@_contentMaxWidth" Class="pt-5 pb-5">
                    <LoggingErrorBoundary @ref="_errorBoundary">
                        <ChildContent>
                            @Body
                        </ChildContent>
                        <ErrorContent Context="exception">
                            <UnhandledError Exception="@exception" OnRecover="RecoverFromError" />
                        </ErrorContent>
                    </LoggingErrorBoundary>

                    <div class="jim-page-footer mt-5">
                        <MudText Typo="Typo.body2" Class="mud-text-secondary jim-page-footer-text">
                            <span>&copy; @DateTime.UtcNow.Year</span>
                            <MudLink Href="https://tetron.io" Target="_blank"
                                     Color="Color.Inherit" Underline="Underline.Hover">
                                Tetron
                            </MudLink>
                            <span class="jim-page-footer-sep">|</span>
                            <span>All rights reserved</span>
                            <span class="jim-page-footer-sep">|</span>
                            <span>v@(AppVersion)</span>
                            @if (!string.IsNullOrEmpty(_serviceName))
                            {
                                <span class="jim-page-footer-sep">|</span>
                                <span>@_serviceName</span>
                            }
                            <span class="jim-page-footer-sep">|</span>
                            <MudLink Href="https://junctional.io" Target="_blank"
                                     Color="Color.Inherit" Underline="Underline.Hover" Class="jim-page-footer-junctional">
                                <span class="jim-page-footer-junctional-icon" aria-hidden="true"></span>
                                <span>junctional.io</span>
                            </MudLink>
                            <span class="jim-page-footer-sep">|</span>
                            <MudLink Href="https://github.com/TetronIO/JIM" Target="_blank"
                                     Color="Color.Inherit" Underline="Underline.Hover" Class="jim-page-footer-github">
                                <MudIcon Icon="@Icons.Custom.Brands.GitHub" Size="Size.Small" Class="jim-page-footer-github-icon" />
                                <span>GitHub</span>
                            </MudLink>
                        </MudText>
                    </div>

                </MudContainer>
            </CascadingValue>
        </MudMainContent>

    </MudDrawerContainer>

</MudLayout>

@code
{
    // Colour palettes are defined in CSS theme files (wwwroot/css/themes/).
    // To experiment with colours, edit or create new theme CSS files.
    private readonly MudTheme _theme = new()
    {
        Typography = new Typography()
        {
            Default = new DefaultTypography()
            {
                FontFamily =
                [
                    "IBM Plex Sans",
                    "-apple-system",
                    "Segoe UI Variable Display",
                    "Helvetica Neue",
                    "Arial"
                ],
                FontWeight = "400",
                FontSize = "16px"
            },
            // MudBlazor 9 defaults (from Material Design 1.0) mix weights 300-500
            // across H1-H6 with large, uneven size jumps between levels (H1 alone
            // ships at 96px). Override the whole scale with a uniform 2px step,
            // starting from H6 at 2px above body text size (16px), so it stays
            // visually close to surrounding text while remaining distinguishable
            // via weight alone.
            H1 = new H1Typography()
            {
                FontSize = "28px",
                FontWeight = "450"
            },
            H2 = new H2Typography()
            {
                FontSize = "26px",
                FontWeight = "450"
            },
            H3 = new H3Typography()
            {
                FontSize = "24px",
                FontWeight = "450"
            },
            H4 = new H4Typography()
            {
                FontSize = "22px",
                FontWeight = "500"
            },
            H5 = new H5Typography()
            {
                FontSize = "20px",
                FontWeight = "500"
            },
            H6 = new H6Typography()
            {
                FontSize = "18px",
                FontWeight = "500"
            }
        },
        LayoutProperties = new LayoutProperties()
        {
            DefaultBorderRadius = "4px"
        }
    };

    private static readonly string AppVersion = GetCleanVersion();

    private static string GetCleanVersion()
    {
        var version = (System.Reflection.CustomAttributeExtensions
            .GetCustomAttribute<System.Reflection.AssemblyInformationalVersionAttribute>(typeof(MainLayout).Assembly))
            ?.InformationalVersion ?? "unknown";
        // Strip the source link commit hash suffix (e.g. "+6444a6934e...")
        var plusIndex = version.IndexOf('+');
        return plusIndex >= 0 ? version[..plusIndex] : version;
    }

    private LoggingErrorBoundary? _errorBoundary;
    private MudThemeProvider? _mudThemeProvider;
    // Minimum viewport width (in pixels) to have drawer open by default
    // 1400px is a common breakpoint for "large" screens
    private const int LargeScreenBreakpoint = 1400;
    // Content container width - pages can request full width via SetFullWidth()
    private MaxWidth _contentMaxWidth = MaxWidth.ExtraLarge;
    private string? _serviceName;

    /// <summary>
    /// Called by pages that implement IFullWidthPage to remove the max-width constraint.
    /// </summary>
    public void SetFullWidth()
    {
        if (_contentMaxWidth != MaxWidth.False)
        {
            _contentMaxWidth = MaxWidth.False;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Resets the content area to the default max-width.
    /// </summary>
    public void ResetWidth()
    {
        if (_contentMaxWidth != MaxWidth.ExtraLarge)
        {
            _contentMaxWidth = MaxWidth.ExtraLarge;
            StateHasChanged();
        }
    }

    // Default to closed/unpinned - will be set based on screen size or saved preference in OnAfterRenderAsync
    private bool IsDrawerOpen { get; set; }
    private bool IsDrawerPinned { get; set; }
    private bool _drawerPinnedInitialised;
    private bool _isDarkMode;
    private bool _darkModeInitialised;
    private bool IsDarkMode
    {
        get => _isDarkMode;
        set
        {
            if (_isDarkMode != value)
            {
                _isDarkMode = value;
                _ = UpdateDarkModeClassAsync(value);
                // Persist the user's explicit choice (skip during initial load)
                if (_darkModeInitialised)
                {
                    _ = PreferenceService.SetDarkModeAsync(value);
                }
            }
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Check for a saved dark mode preference first, fall back to system setting
                var savedDarkMode = await PreferenceService.GetDarkModeAsync();
                if (savedDarkMode.HasValue)
                {
                    _isDarkMode = savedDarkMode.Value;
                }
                else if (_mudThemeProvider != null)
                {
                    _isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();
                }
                await UpdateDarkModeClassAsync(_isDarkMode);
                _darkModeInitialised = true;

                // Check for a saved drawer pinned preference, fall back to screen size
                var savedDrawerPinned = await PreferenceService.GetDrawerPinnedAsync();
                if (savedDrawerPinned.HasValue)
                {
                    IsDrawerPinned = savedDrawerPinned.Value;
                    IsDrawerOpen = savedDrawerPinned.Value;
                }
                else
                {
                    var windowWidth = await JSRuntime.InvokeAsync<int>("jimInterop.getWindowInnerWidth");
                    var isLargeScreen = windowWidth >= LargeScreenBreakpoint;
                    IsDrawerOpen = isLargeScreen;
                    IsDrawerPinned = isLargeScreen;
                }
                _drawerPinnedInitialised = true;

                StateHasChanged();
            }
            catch (JSDisconnectedException)
            {
                // Ignore - circuit is disconnected and being disposed
            }
        }
    }

    protected override async Task OnInitializedAsync()
    {
        using var jim = JimFactory.Create();
        _serviceName = await jim.ServiceSettings.GetSettingValueAsync<string>(
            JIM.Models.Core.Constants.SettingKeys.ServiceName);

        NavigationManager.LocationChanged += OnLocationChanged;
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        _errorBoundary?.Recover();
    }

    private void RecoverFromError()
    {
        _errorBoundary?.Recover();
    }

    private string LightThemePath => ThemeSettings.LightThemePath;
    private string DarkThemePath => ThemeSettings.DarkThemePath;

    private async Task UpdateDarkModeClassAsync(bool isDark)
    {
        try
        {
            var themePath = isDark ? DarkThemePath : LightThemePath;

            // Swap the theme CSS file
            await JSRuntime.InvokeVoidAsync("jimInterop.setThemeStylesheet", themePath);

            // Maintain body class for any custom CSS selectors
            await JSRuntime.InvokeVoidAsync("jimInterop.setBodyClass", "jim-dark-mode", isDark);
        }
        catch (JSDisconnectedException)
        {
            // Ignore - circuit is disconnected
        }
    }

    private void ToggleDrawerPinned()
    {
        IsDrawerPinned = !IsDrawerPinned;
        // When pinning, ensure drawer stays open. When unpinning, close it.
        IsDrawerOpen = IsDrawerPinned;
        if (_drawerPinnedInitialised)
        {
            _ = PreferenceService.SetDrawerPinnedAsync(IsDrawerPinned);
        }
    }

    private void OnDrawerMouseEnter()
    {
        // Only respond to hover if not pinned
        if (!IsDrawerPinned)
        {
            IsDrawerOpen = true;
        }
    }

    private void OnDrawerMouseLeave()
    {
        // Only respond to hover if not pinned
        if (!IsDrawerPinned)
        {
            IsDrawerOpen = false;
        }
    }

    public void Dispose()
    {
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
