@page "/dev/error-pages"
@using Microsoft.Extensions.Hosting
@inject IWebHostEnvironment Environment
@inject NavigationManager NavigationManager

@if (!Environment.IsDevelopment())

@* Copyright (c) Tetron Limited. All rights reserved. *@
@* Licensed under the Tetron Commercial License. See LICENSE file in the project root. *@
{
    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">This page is only available in the Development environment.</MudAlert>
}
else
{
    <MudText Typo="Typo.h4" Class="mb-2">Error Page Preview</MudText>
    <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mb-4">
        Preview error pages during development. These components are shown to users when something goes wrong.
    </MudText>

    <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" TabPanelsClass="pa-6" Outlined="true">
        <MudTabPanel Text="Unhandled Error">
            <UnhandledError Exception="@_sampleException" OnRecover="@(() => { })" />
        </MudTabPanel>
        <MudTabPanel Text="Not Authorised">
            <UserNotAuthorised />
        </MudTabPanel>
        <MudTabPanel Text="Live Error Test">
            <MudText Typo="Typo.body1" Class="mb-3">
                Click the button below to trigger a real unhandled exception. The error boundary in MainLayout will catch it and display the error page.
            </MudText>
            <MudButton Variant="Variant.Filled" Color="Color.Error"
                       StartIcon="@Icons.Material.Filled.BugReport"
                       OnClick="TriggerError">Trigger Unhandled Exception</MudButton>
        </MudTabPanel>
    </MudTabs>
}

@code {
    private readonly Exception _sampleException = new InvalidOperationException(
        "This is a sample exception for previewing the error page.");

    private void TriggerError()
    {
        throw new InvalidOperationException("This is a test exception triggered from the dev error page preview.");
    }
}
