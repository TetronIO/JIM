<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">
                Optionally describe why you are making this change. The reason is recorded against the change in the configuration change history.
            </MudText>
            <MudTextField @bind-Value="_reason" Label="Reason (optional)" Variant="Variant.Outlined"
                Lines="3" MaxLines="8" Sizing="InputSizing.Auto" AutoFocus="true" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit">@ActionText</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    /// <summary>
    /// The label for the confirm button, mirroring the action the user clicked to get here (e.g. "Save", "Create").
    /// </summary>
    [Parameter]
    public string ActionText { get; set; } = "Save";

    private string? _reason;

    /// <summary>
    /// Opens the dialog and returns the outcome: Cancelled true when the user backed out of the save entirely,
    /// otherwise the optional reason (null when none was given). Call from a save handler before persisting.
    /// </summary>
    public static async Task<(bool Cancelled, string? Reason)> ShowAsync(IDialogService dialogService, string actionText = "Save")
    {
        var parameters = new DialogParameters<ChangeReasonDialog>
        {
            { x => x.ActionText, actionText }
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Small,
            FullWidth = true,
            CloseOnEscapeKey = true
        };
        var dialog = await dialogService.ShowAsync<ChangeReasonDialog>("Reason for change", parameters, options);
        var result = await dialog.Result;
        return result is null or { Canceled: true }
            ? (true, null)
            : (false, result.Data as string);
    }

    private void Cancel() => MudDialog.Cancel();

    // The reason is optional: an empty submission closes with a null result rather than blocking the save.
    private void Submit() => MudDialog.Close(DialogResult.Ok(
        string.IsNullOrWhiteSpace(_reason) ? null : _reason.Trim()));
}
