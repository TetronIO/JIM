@* Field-history rendering of a configuration diff: an audit-style "before → after" per changed field, with a whole
   added / removed item shown as a small card rather than a green / red subtree. Renders the ConfigurationDiff produced
   by the change-history and compare endpoints. *@

@if (Diff != null)
{
    <ConfigurationDiffSummary Diff="Diff" />

    @if (Diff.Root.ChangeType == ConfigurationDiffChangeType.Added)
    {
        <MudAlert Severity="Severity.Success" Variant="Variant.Outlined" Dense="true" Class="mb-3">This object was created at this version.</MudAlert>
    }
    else if (Diff.Root.ChangeType == ConfigurationDiffChangeType.Removed)
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mb-3">This object was deleted at this version.</MudAlert>
    }

    @if (!Diff.HasChanges)
    {
        <MudText Typo="Typo.body2" Class="mud-text-secondary">No differences between these versions.</MudText>
    }
    else
    {
        <div>
            @foreach (var child in Diff.Root.Children ?? new List<ConfigurationDiffNode>())
            {
                <ConfigurationChangeFieldNode Node="child" Depth="0" Context="_rootContext" />
            }
        </div>
    }
}

@code {
    /// <summary>The structured configuration diff to render in the field-history style.</summary>
    [Parameter, EditorRequired]
    public ConfigurationDiff Diff { get; set; } = null!;

    // A wholly created (or deleted) object renders every field as a plain "label: value" rather than "before → after",
    // since there is no previous (or next) state to compare against.
    private DiffRenderContext _rootContext;

    protected override void OnParametersSet()
    {
        _rootContext = Diff?.Root.ChangeType switch
        {
            ConfigurationDiffChangeType.Added => DiffRenderContext.Added,
            ConfigurationDiffChangeType.Removed => DiffRenderContext.Removed,
            _ => DiffRenderContext.Normal
        };
    }
}
