@* Recursively renders one node of a configuration diff tree, git-style: additions green, removals red,
   a modified scalar shows its old value (red) then its new value (green), and a changed secret is shown
   amber with its value hidden. Unchanged nodes (scalars and containers alike) render nothing, so the diff
   shows only what actually changed. A changed container renders a muted context header with just its
   changed descendants beneath it. *@

@if (Node.NodeType == ConfigurationSnapshotNodeType.Scalar)
{
    @* The label is rendered neutral (grey) and only the value carries the add/remove colour, so a value is easy to
       pick out from its field name. The +/- sigil keeps the add/remove signal. *@
    @if (Node.ChangeType == ConfigurationDiffChangeType.Modified && !Node.IsSecret)
    {
        <div style="@_indent">
            <MudText Typo="Typo.body2" Color="Color.Error" Style="@MonospaceStyle">- <span class="mud-text-secondary">@(_label):</span> @_oldDisplay</MudText>
        </div>
        <div style="@_indent">
            <MudText Typo="Typo.body2" Color="Color.Success" Style="@MonospaceStyle">+ <span class="mud-text-secondary">@(_label):</span> @_newDisplay</MudText>
        </div>
    }
    else if (_scalarSigil != null)
    {
        <div style="@_indent">
            <MudText Typo="Typo.body2" Color="@_scalarColour" Style="@MonospaceStyle">@_scalarSigil <span class="mud-text-secondary">@(_label):</span> @_scalarValue</MudText>
        </div>
    }
    else if (_scalarLine != null)
    {
        <div style="@_indent">
            <MudText Typo="Typo.body2" Color="@_scalarColour" Style="@MonospaceStyle">@_scalarLine</MudText>
        </div>
    }
}
else
{
    @* Object or Collection node. Unchanged containers render nothing; only changed branches are shown. A collection whose
       own label merely repeats its items' label (e.g. an "Attribute Flow" collection of "Attribute Flow" items) is
       rendered transparently: no grouping header, and its items appear at the collection's own depth, so there is no
       redundant grey line above identically-named items. *@
    @if (Node.ChangeType != ConfigurationDiffChangeType.Unchanged && !_emptyCollection)
    {
        @if (!_transparentCollection)
        {
            <div style="@_indent">
                <MudText Typo="Typo.body2" Color="@_containerColour" Class="@_containerClass" Style="@MonospaceStyle">@_containerHeader</MudText>
            </div>
        }
        @if (Node.Children != null)
        {
            @foreach (var child in Node.Children)
            {
                <ConfigurationChangeDiffNode Node="child" Depth="@(_transparentCollection ? Depth : Depth + 1)" />
            }
        }
    }
}

@code {
    /// <summary>The diff node to render.</summary>
    [Parameter, EditorRequired]
    public ConfigurationDiffNode Node { get; set; } = null!;

    /// <summary>Nesting depth, used for indentation; 0 for a top-level section.</summary>
    [Parameter]
    public int Depth { get; set; }

    private const string MonospaceStyle = "font-family: monospace; white-space: pre-wrap;";

    private string _label = string.Empty;
    private string _indent = string.Empty;

    // Display strings prefer the captured human-friendly DisplayValue (FK "Name (id)", spaced enum), falling back to the
    // raw value when none was captured (older snapshots, plain text/number/boolean fields).
    private string? _oldDisplay;
    private string? _newDisplay;

    // Pre-computed presentation for an added/removed non-secret scalar, split so the label renders neutral and the value
    // renders in the add/remove colour.
    private string? _scalarSigil;
    private string? _scalarValue;

    // Pre-computed presentation for the plain single-line cases (a changed/added/removed secret note).
    private string? _scalarLine;
    private Color _scalarColour = Color.Default;

    // Pre-computed presentation for a container header (object/collection that changed).
    private string _containerHeader = string.Empty;
    private Color _containerColour = Color.Default;
    private string? _containerClass;

    // True when this collection's own label merely repeats its items' label, so its grouping header is redundant and it
    // is rendered transparently (items pulled up to its own depth).
    private bool _transparentCollection;

    // True when this is a collection with no items (e.g. an added object type whose attributes are not yet configured).
    // An empty collection is not worth a "+ Attributes" line with nothing under it, so it renders nothing.
    private bool _emptyCollection;

    protected override void OnParametersSet()
    {
        _label = string.IsNullOrEmpty(Node.Label) ? Node.Key : Node.Label;
        _indent = $"padding-left: {Depth * 24}px;";
        _scalarLine = null;
        _scalarSigil = null;
        _scalarValue = null;
        _containerClass = null;
        _oldDisplay = Node.OldDisplayValue ?? Node.OldValue;
        _newDisplay = Node.NewDisplayValue ?? Node.NewValue;

        _emptyCollection = Node.NodeType == ConfigurationSnapshotNodeType.Collection
            && (Node.Children == null || Node.Children.Count == 0);

        _transparentCollection = Node.NodeType == ConfigurationSnapshotNodeType.Collection
            && Node.ChangeType != ConfigurationDiffChangeType.Unchanged
            && Node.Children is { Count: > 0 }
            && Node.Children.All(c => EffectiveLabel(c) == _label);

        if (Node.NodeType == ConfigurationSnapshotNodeType.Scalar)
        {
            switch (Node.ChangeType)
            {
                case ConfigurationDiffChangeType.Added when Node.IsSecret:
                    _scalarLine = $"+ {_label}  (secret set)";
                    _scalarColour = Color.Success;
                    break;
                case ConfigurationDiffChangeType.Added:
                    _scalarSigil = "+";
                    _scalarValue = _newDisplay;
                    _scalarColour = Color.Success;
                    break;
                case ConfigurationDiffChangeType.Removed when Node.IsSecret:
                    _scalarLine = $"- {_label}  (secret removed)";
                    _scalarColour = Color.Error;
                    break;
                case ConfigurationDiffChangeType.Removed:
                    _scalarSigil = "-";
                    _scalarValue = _oldDisplay;
                    _scalarColour = Color.Error;
                    break;
                case ConfigurationDiffChangeType.Modified when Node.IsSecret:
                    _scalarLine = $"~ {_label}  (secret changed; value hidden)";
                    _scalarColour = Color.Warning;
                    break;
                // A modified non-secret scalar is rendered as two lines in markup; an unchanged scalar renders nothing.
            }
        }
        else
        {
            switch (Node.ChangeType)
            {
                case ConfigurationDiffChangeType.Added:
                    _containerHeader = $"+ {_label}";
                    _containerColour = Color.Success;
                    break;
                case ConfigurationDiffChangeType.Removed:
                    _containerHeader = $"- {_label}";
                    _containerColour = Color.Error;
                    break;
                default:
                    // Modified: a muted context header, with only the changed descendants rendered beneath it.
                    _containerHeader = _label;
                    _containerColour = Color.Default;
                    _containerClass = "mud-text-secondary";
                    break;
            }
        }
    }

    private static string EffectiveLabel(ConfigurationDiffNode node) => string.IsNullOrEmpty(node.Label) ? node.Key : node.Label;
}
