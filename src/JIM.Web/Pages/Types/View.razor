<PageTitle>@(MetaverseObject == null ? "Loading…" : $"{MetaverseObjectType?.Name}: {_displayName}")</PageTitle>

<LoadingGate IsLoading="@(MetaverseObject == null)">
    <Loading>
        <MvoDetailSkeleton />
    </Loading>
    <LongLoadMessage>
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Still loading. Large objects can take a few seconds to retrieve.
        </MudAlert>
    </LongLoadMessage>
    <Loaded>
<MudText Typo="Typo.h4"><MudIcon Icon="@Helpers.ResolveObjectTypeIcon(MetaverseObjectType?.Icon)" Size="Size.Large" Class="mr-2 mb-1" Style="vertical-align: middle;" /><span>@MetaverseObjectType?.Name:</span> <span class="mud-primary-text">@_displayName</span></MudText>
<MudBreadcrumbs Items="_breadcrumbs" Class="ps-0"></MudBreadcrumbs>

@if (MetaverseObject != null)
{
    <NavigableMudTabs ActivePanelIndex="_activeTabIndex" ActivePanelIndexChanged="OnActiveTabIndexChangedAsync" Elevation="0" Rounded="true" ApplyEffectsToContainer="false" Outlined="true" Class="mt-2" TabPanelsClass="pa-0">
        <Header Context="headerContext">
            @if (_activeTabIndex == 0)
            {
                <MudSpacer />
                <MudButtonGroup OverrideStyles="false" Class="my-auto me-2">
                    <MudButton Variant="@(_detailViewMode == "form" ? Variant.Filled : Variant.Outlined)"
                               Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.ViewModule"
                               OnClick="@(() => OnDetailViewModeChangedAsync("form"))">Form</MudButton>
                    <MudButton Variant="@(_detailViewMode == "tabs" ? Variant.Filled : Variant.Outlined)"
                               Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.Tab"
                               OnClick="@(() => OnDetailViewModeChangedAsync("tabs"))">Tabs</MudButton>
                    <MudButton Variant="@(_detailViewMode == "table" ? Variant.Filled : Variant.Outlined)"
                               Color="Color.Primary" Size="Size.Small"
                               StartIcon="@Icons.Material.Filled.ViewList"
                               OnClick="@(() => OnDetailViewModeChangedAsync("table"))">Table</MudButton>
                </MudButtonGroup>
            }
        </Header>
        <ChildContent>
        <MudTabPanel Text="Details" Icon="@Icons.Material.Filled.Info">
            @if (_detailViewMode == "table")
            {
                <MvoDetailsTable MetaverseObject="MetaverseObject" AttributeValueTotalCounts="_attributeValueTotalCounts" />
            }
            else if (_detailViewMode == "tabs")
            {
                <MvoDetailsTabs MetaverseObject="MetaverseObject" ObjectTypeId="MetaverseObjectType!.Id" AttributeValueTotalCounts="_attributeValueTotalCounts" />
            }
            else
            {
                <MvoDetailsPanel MetaverseObject="MetaverseObject" ObjectTypeId="MetaverseObjectType!.Id" AttributeValueTotalCounts="_attributeValueTotalCounts" />
            }
        </MudTabPanel>

        <MudTabPanel Text="Changes" Icon="@Icons.Material.Filled.History" BadgeData="@GetChangeBadge()" BadgeColor="Color.Primary">
            <div class="mt-3">
                @if (_changeHistoryLoading && _changeHistoryRows.Count == 0)
                {
                    <div class="d-flex justify-center pa-4">
                        <MudProgressCircular Indeterminate="true" />
                    </div>
                }
                else if (_changeCount == 0)
                {
                    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">No change history recorded for this object.</MudAlert>
                }
                else
                {
                    <ChangeHistoryTimeline Changes="@_changeHistoryRows" />
                    @if (_changeHistoryRows.Count < _changeHistoryTotal)
                    {
                        <div class="d-flex justify-center mt-3">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Primary"
                                       Disabled="@_changeHistoryLoading"
                                       OnClick="LoadMoreChangeHistoryAsync">
                                @if (_changeHistoryLoading)
                                {
                                    <MudProgressCircular Indeterminate="true" Size="Size.Small" Class="me-2" />
                                }
                                Load more (@($"{_changeHistoryTotal - _changeHistoryRows.Count:N0}") remaining)
                            </MudButton>
                        </div>
                    }
                }
            </div>
        </MudTabPanel>

        <MudTabPanel Text="Properties" Icon="@Icons.Material.Filled.Assignment">
            <MudPaper Class="pa-4 mt-3" Outlined="true">
                <MudGrid Spacing="4">
                    <MudItem xs="12" sm="6" md="4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Id</MudText>
                        <br />
                        <MudTooltip Text="Click to copy">
                            <ChildContent>
                                <MudText Typo="Typo.body1" Style="cursor: pointer; word-break: break-all;" @onclick="@(() => CopyToClipboardAsync(MetaverseObject.Id.ToString()))">
                                    @MetaverseObject.Id
                                </MudText>
                            </ChildContent>
                        </MudTooltip>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Created</MudText>
                        <br />
                        <MudTooltip Text="@MetaverseObject.Created.ToString("O")">
                            <ChildContent>
                                <MudText Typo="Typo.body1">@MetaverseObject.Created.ToFriendlyDate()</MudText>
                            </ChildContent>
                        </MudTooltip>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Created By</MudText>
                        <br />
                        @if (_createdByHref != null)
                        {
                            <MudLink Typo="Typo.body1" Href="@_createdByHref">@_createdByName</MudLink>
                        }
                        else
                        {
                            <MudText Typo="Typo.body1">@(_createdByName ?? "—")</MudText>
                        }
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Last Updated</MudText>
                        @if (MetaverseObject.LastUpdated.HasValue)
                        {
                            <MudTooltip Text="@MetaverseObject.LastUpdated.Value.ToString("O")">
                                <ChildContent>
                                    <MudText Typo="Typo.body1">@MetaverseObject.LastUpdated.Value.ToFriendlyDate()</MudText>
                                </ChildContent>
                            </MudTooltip>
                        }
                        else
                        {
                            <MudText Typo="Typo.body1">—</MudText>
                        }
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Last Updated By</MudText>
                        <br />
                        @if (_lastUpdatedByHref != null)
                        {
                            <MudLink Typo="Typo.body1" Href="@_lastUpdatedByHref">@_lastUpdatedByName</MudLink>
                        }
                        else
                        {
                            <MudText Typo="Typo.body1">@(_lastUpdatedByName ?? "—")</MudText>
                        }
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Status</MudText>
                        <MudText Typo="Typo.body1">@MetaverseObject.Status</MudText>
                    </MudItem>
                    <MudItem xs="12" sm="6" md="4">
                        <MudText Typo="Typo.caption" Class="mud-text-secondary">Origin</MudText>
                        <MudText Typo="Typo.body1">@MetaverseObject.Origin</MudText>
                    </MudItem>
                </MudGrid>
            </MudPaper>
        </MudTabPanel>
        </ChildContent>
    </NavigableMudTabs>
}
    </Loaded>
</LoadingGate>

@code {
    [Parameter]
    public string TypeNameUrlParam { get; set; } = null!;
    [Parameter]
    public Guid IdParam { get; set; }
    private MetaverseObject? MetaverseObject { get; set; }
    private MetaverseObjectType? MetaverseObjectType { get; set; }
    private string? _displayName;
    private int _activeTabIndex = 0;
    private string _detailViewMode = "form";
    private Dictionary<string, int> _attributeValueTotalCounts = new();
    private List<BreadcrumbItem> _breadcrumbs = null!;
    private string? _createdByName;
    private string? _createdByHref;
    private string? _lastUpdatedByName;
    private string? _lastUpdatedByHref;

    // Change-history lazy-load state. Initial detail load returns only the count so the
    // badge can render immediately; the rows are fetched the first time the user lands
    // on the Changes tab and paged via Load more.
    private const int ChangeHistoryPageSize = 50;
    private int _changeCount;
    private int _changeHistoryTotal;
    private int _changeHistoryNextPage = 1;
    private bool _changeHistoryLoading;
    private readonly List<ChangeHistoryTimeline.ChangeGroup> _changeHistoryRows = new();

    protected override async Task OnParametersSetAsync()
    {
        // If ?c= is present, force tabs view (overrides saved preference)
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        if (query["c"] != null)
        {
            _detailViewMode = "tabs";
        }
        else
        {
            // Load user's preferred detail view mode (form, tabs, or table)
            try
            {
                var savedMode = await UserPreferences.GetMvoDetailViewModeAsync();
                if (savedMode != null)
                    _detailViewMode = savedMode;
            }
            catch
            {
                // JS interop not yet available; keep default
            }
        }

        using var jim = JimFactory.Create();
        var pluralName = Helpers.ConvertFromUrlParam(TypeNameUrlParam);
        MetaverseObjectType = await jim.Metaverse.GetMetaverseObjectTypeByPluralNameAsync(pluralName, false);
        if (MetaverseObjectType == null)
        {
            NavManager.NavigateTo("/");
            return;
        }

        // Load MVO with capped MVA values for efficient rendering
        var detailResult = await jim.Metaverse.GetMetaverseObjectDetailAsync(IdParam, MvoAttributeLoadStrategy.CappedMva);
        if (detailResult == null)
        {
            NavManager.NavigateTo("/");
            return;
        }

        MetaverseObject = detailResult.MetaverseObject;
        _attributeValueTotalCounts = detailResult.AttributeValueTotalCounts;
        _changeCount = detailResult.ChangeCount;

        _displayName = MetaverseObject.DisplayName;

        if (detailResult.EarliestChangeInitiator != null)
        {
            _createdByName = detailResult.EarliestChangeInitiator.InitiatedByName;
            _createdByHref = GetInitiatorHref(detailResult.EarliestChangeInitiator.InitiatedByType, detailResult.EarliestChangeInitiator.InitiatedById);
        }
        if (detailResult.LatestChangeInitiator != null)
        {
            _lastUpdatedByName = detailResult.LatestChangeInitiator.InitiatedByName;
            _lastUpdatedByHref = GetInitiatorHref(detailResult.LatestChangeInitiator.InitiatedByType, detailResult.LatestChangeInitiator.InitiatedById);
        }

        if (MetaverseObject.DisplayName != null)
            _breadcrumbs = new List<BreadcrumbItem>
            {
                new("Home", href: "/", icon: Icons.Material.Filled.Home),
                new(MetaverseObjectType.PluralName, href: $"/t/{MetaverseObjectType.PluralName.ToLower()}"),
                new(MetaverseObjectType.Name, href: null, disabled: true)
            };
    }

    private async Task OnDetailViewModeChangedAsync(string mode)
    {
        _detailViewMode = mode;
        await UserPreferences.SetMvoDetailViewModeAsync(_detailViewMode);

        // Clean up the ?cat= query parameter when leaving tabs view
        if (mode != "tabs")
        {
            var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
            var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
            if (query["c"] != null)
            {
                query.Remove("c");
                var baseUri = uri.GetLeftPart(UriPartial.Path);
                var qs = query.ToString();
                var newUrl = string.IsNullOrEmpty(qs) ? baseUri : $"{baseUri}?{qs}";
                NavManager.NavigateTo(newUrl, new NavigationOptions { ReplaceHistoryEntry = true });
            }
        }
    }

    private string GetChangeBadge()
    {
        return _changeCount.ToString("N0");
    }

    private async Task OnActiveTabIndexChangedAsync(int newIndex)
    {
        _activeTabIndex = newIndex;
        // Lazy-load the first page of change history when the user lands on the Changes tab.
        if (newIndex == 1 && _changeHistoryRows.Count == 0 && _changeCount > 0 && !_changeHistoryLoading)
            await LoadChangeHistoryPageAsync();
    }

    private async Task LoadMoreChangeHistoryAsync()
    {
        await LoadChangeHistoryPageAsync();
    }

    private async Task LoadChangeHistoryPageAsync()
    {
        if (_changeHistoryLoading)
            return;

        _changeHistoryLoading = true;
        StateHasChanged();
        try
        {
            using var jim = JimFactory.Create();
            var (items, totalCount) = await jim.Metaverse.GetMvoChangeHistoryAsync(IdParam, _changeHistoryNextPage, ChangeHistoryPageSize);
            _changeHistoryTotal = totalCount;
            _changeHistoryRows.AddRange(items.Select(MapDtoToChangeGroup));
            _changeHistoryNextPage++;
        }
        finally
        {
            _changeHistoryLoading = false;
            StateHasChanged();
        }
    }

    private static ChangeHistoryTimeline.ChangeGroup MapDtoToChangeGroup(MvoChangeHistoryDto dto)
    {
        return new ChangeHistoryTimeline.ChangeGroup
        {
            ChangeType = dto.ChangeType,
            ChangeTime = dto.ChangeTime,
            ChangeInitiatorType = dto.InitiatedByType.ToString(),
            ChangeInitiatorName = dto.InitiatedByName,
            ChangeInitiatorId = dto.InitiatedById,
            ChangeMechanismType = MapDtoToMechanismType(dto),
            RunProfileName = dto.RunProfileName,
            ConnectedSystemId = dto.ConnectedSystemId,
            ConnectedSystemName = dto.ConnectedSystemName,
            SyncRuleId = dto.SyncRuleId,
            SyncRuleName = dto.SyncRuleName,
            ActivityRunProfileExecutionItemId = dto.ActivityRunProfileExecutionItemId,
            CsoId = dto.CsoId,
            CsoExternalId = dto.CsoExternalId,
            AttributeChanges = dto.AttributeChanges
                .SelectMany(ac => ac.ValueChanges.Select(vc => new ChangeHistoryTimeline.AttributeChange
                {
                    AttributeName = ac.AttributeName,
                    ChangeType = vc.ValueChangeType,
                    Value = vc.ReferenceValue == null ? vc.ToDisplayString() : null,
                    ReferenceValue = vc.ReferenceValue != null
                        ? new ChangeHistoryTimeline.ReferenceValueInfo
                        {
                            TypeName = vc.ReferenceValue.TypeName,
                            DisplayName = vc.ReferenceValue.DisplayName ?? vc.ReferenceValue.Id.ToString(),
                            SecondaryId = null,
                            Href = Utilities.GetMetaverseObjectHref(vc.ReferenceValue.Id, vc.ReferenceValue.TypePluralName)
                        }
                        : null,
                    IsMultiValued = ac.AttributePlurality == AttributePlurality.MultiValued,
                    AttributeType = ac.AttributeType
                }))
                .ToList()
        };
    }

    private async Task CopyToClipboardAsync(string text)
    {
        await JsRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private static string? GetInitiatorHref(ActivityInitiatorType initiatedByType, Guid? initiatedById)
    {
        if (initiatedById == null)
            return null;

        return initiatedByType switch
        {
            ActivityInitiatorType.User => $"/t/users/v/{initiatedById}",
            ActivityInitiatorType.ApiKey => $"/admin/apikeys/{initiatedById}",
            _ => null
        };
    }

    private static string MapDtoToMechanismType(MvoChangeHistoryDto dto)
    {
        if (dto.ChangeInitiatorType is MetaverseObjectChangeInitiatorType.ExampleData
            or MetaverseObjectChangeInitiatorType.User
            or MetaverseObjectChangeInitiatorType.WorkflowInstance
            or MetaverseObjectChangeInitiatorType.GroupMembershipRuleEvaluation
            or MetaverseObjectChangeInitiatorType.System)
        {
            return dto.ChangeInitiatorType.ToString();
        }

        return dto.ConnectedSystemRunType switch
        {
            ConnectedSystemRunType.FullImport or ConnectedSystemRunType.DeltaImport => "Import",
            ConnectedSystemRunType.FullSynchronisation or ConnectedSystemRunType.DeltaSynchronisation => "SynchronisationRule",
            ConnectedSystemRunType.Export => "Export",
            _ => "SynchronisationRule"
        };
    }
}