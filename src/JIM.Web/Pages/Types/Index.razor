@page "/t/{TypeNameUrlParam}"
@page "/t/{TypeNameUrlParam}/s/{PredefinedSearchUri}"
@attribute [Authorize(Roles = "User")]
@using JIM.Models.Core
@using JIM.Models.Core.DTOs
@using JIM.Models.Search
@using JIM.Models.Utility
@using JIM.Utilities
@using JIM.Web.Services
@inject IJimApplicationFactory JimFactory
@inject NavigationManager NavManager
@inject IUserPreferenceService PreferenceService

@* Copyright (c) Tetron Limited. All rights reserved. *@
@* Licensed under the Tetron Commercial License. See LICENSE file in the project root. *@

<PageTitle>@PageTitle</PageTitle>
<MudText Typo="Typo.h3"><MudIcon Icon="@Helpers.ResolveObjectTypeIcon(MetaverseObjectType?.Icon)" Size="Size.Large" Class="mr-2 mb-1" Style="vertical-align: middle;" />@PageTitle</MudText>
<MudBreadcrumbs Items="_breadcrumbs" Class="ps-0"></MudBreadcrumbs>
<MudText Typo="Typo.subtitle1" Class="mud-text-secondary">Search, or browse for @ObjectTypeName</MudText>

@if (_isInitialised && _preferencesLoaded && PredefinedSearch != null)
{
    @if (_hasAttributeName != null)
    {
        <MudChip T="string" Color="Color.Primary" Variant="Variant.Text" Icon="@Icons.Material.Filled.FilterAlt"
                 OnClose="ClearHasAttributeFilter" Class="mt-3">Has a value for: @_hasAttributeName</MudChip>

        @if (_hasAttributeUnknown)
        {
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mt-2">
                No Metaverse Attribute named "@_hasAttributeName" is defined, so no objects match. Clear the filter to browse all @MetaverseObjectType?.PluralName.
            </MudAlert>
        }
    }

    <MudTable @ref="_table" T="MetaverseObjectHeader" ServerData="ServerReload" @bind-CurrentPage="_currentPage" RowsPerPage="@_rowsPerPage" RowsPerPageChanged="OnRowsPerPageChanged" Hover="true"
        Dense="@_dense" Breakpoint="Breakpoint.Sm" Class="@(_dense ? "mt-5 dense-body-only" : "mt-5")" Outlined="true" Elevation="0" OnRowClick="HandleRowClick"
        RowClass="cursor-pointer" Loading="@_loading" LoadingProgressColor="Color.Primary">
        <ToolBarContent>
            <TableDensityToggle @bind-Dense="_dense" />
            <MudSpacer />
            <MudTextField T="string" ValueChanged="@(s => OnSearch(s))" Variant="Variant.Outlined" Placeholder="Search..." Margin="Margin.Dense"
                Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Search" IconSize="Size.Medium"
                Class="mt-0" />
        </ToolBarContent>
        <HeaderContent>
            @foreach (var psa in PredefinedSearch.Attributes)
            {
                <MudTh>
                    <MudTableSortLabel SortLabel="@psa.MetaverseAttribute.Name" T="MetaverseObjectHeader"
                        InitialDirection="@(psa.MetaverseAttribute.Name == Constants.BuiltInAttributes.DisplayName ? SortDirection.Ascending : SortDirection.None)">
                        <MudText Typo="Typo.button">@psa.MetaverseAttribute.Name</MudText>
                    </MudTableSortLabel>
                </MudTh>
            }
        </HeaderContent>
        <RowTemplate>
            <MudTd DataLabel="@Constants.BuiltInAttributes.DisplayName">
                <MudLink Href="@Utilities.GetMetaverseObjectHref(context)">@Utilities.GetMetaverseObjectHrefText(context)</MudLink>
            </MudTd>
            @foreach (var psa in PredefinedSearch.Attributes.Where(q => q.MetaverseAttribute.Name != Constants.BuiltInAttributes.DisplayName))
            {
                var value = context.GetAttributeValue(psa.MetaverseAttribute.Name)?.StringValue;
                <MudTd DataLabel="@psa.MetaverseAttribute.Name">
                    @if (string.IsNullOrEmpty(value))
                    {
                        <EmptyValue />
                    }
                    else
                    {
                        @value
                    }
                </MudTd>
            }
        </RowTemplate>
        <NoRecordsContent>
            No results
        </NoRecordsContent>
        <PagerContent>
            <MudTablePager />
        </PagerContent>
    </MudTable>
}
else if (_isInitialised)
{
    if (!string.IsNullOrEmpty(PredefinedSearchUri))
    {
        <b>No such predefined search found, sorry</b>
    }
    else
    {
        <b>Please create a default Predefined Search for this Metaverse Object Type</b>
    }
}

@code {
    [Parameter]
    public string TypeNameUrlParam { get; set; } = null!;

    [Parameter]
    public string? PredefinedSearchUri { get; set; }

    private MudTable<MetaverseObjectHeader>? _table;
    private string _searchString = "";
    private int _rowsPerPage = 10;
    private bool _preferencesLoaded;
    private bool _loading;
    private bool _isInitialised;
    private bool _dense;
    private int _currentPage;

    // Attribute-presence filter (the ?search=hasAttribute:{name} deep link). _hasAttributeName is the parsed token
    // (null when no presence filter is active); _hasAttributeId is its resolved attribute id; _hasAttributeUnknown is
    // true when a name was supplied but no such attribute exists, in which case no object can match.
    private string? _hasAttributeName;
    private int? _hasAttributeId;
    private bool _hasAttributeUnknown;

    private MetaverseObjectType? MetaverseObjectType { get; set; }
    private PredefinedSearch? PredefinedSearch { get; set; }
    private string? PageTitle { get; set; }
    private string? ObjectTypeName { get; set; }
    private List<BreadcrumbItem> _breadcrumbs = null!;

    protected override async Task OnParametersSetAsync()
    {
        // Reset state when parameters change (e.g., navigating between types)
        _isInitialised = false;
        _hasAttributeName = null;
        _hasAttributeId = null;
        _hasAttributeUnknown = false;

        // Read page from URL query string (MudTable uses 0-indexed pages)
        _currentPage = GetPageFromUrl() - 1;

        using var jim = JimFactory.Create();
        var pluralName = Helpers.ConvertFromUrlParam(TypeNameUrlParam);
        MetaverseObjectType = await jim.Metaverse.GetMetaverseObjectTypeByPluralNameAsync(pluralName, false);
        if (MetaverseObjectType == null)
        {
            NavManager.NavigateTo("/");
            return;
        }

        // Attribute-presence filter from the URL (?search=hasAttribute:{name}). Resolve the name to an attribute id so
        // the table can filter by it; an unrecognised name yields no results (surfaced as a clear empty state).
        var searchToken = GetSearchFromUrl();
        if (!string.IsNullOrWhiteSpace(searchToken) &&
            searchToken.StartsWith(Utilities.HasAttributeSearchToken, StringComparison.OrdinalIgnoreCase))
        {
            var attributeName = searchToken[Utilities.HasAttributeSearchToken.Length..].Trim();
            if (attributeName.Length > 0)
            {
                _hasAttributeName = attributeName;
                var presenceAttribute = await jim.Metaverse.GetMetaverseAttributeAsync(attributeName);
                _hasAttributeId = presenceAttribute?.Id;
                _hasAttributeUnknown = presenceAttribute == null;
            }
        }

        // set a default name for the objects on this page (use PluralName for list views)
        PageTitle = MetaverseObjectType.PluralName;

        // are we being asked to load a specific PredefinedSearch, via the URL?
        if (!string.IsNullOrEmpty(PredefinedSearchUri))
        {
            var search = await jim.Search.GetPredefinedSearchAsync(PredefinedSearchUri);
            // disabled searches are hidden from end users
            if (search is { IsEnabled: true })
                PredefinedSearch = search;
        }
        else
        {
            // is there a default predefined search for this object type?
            var search = await jim.Search.GetPredefinedSearchAsync(MetaverseObjectType);
            // disabled searches are hidden from end users
            if (search is { IsEnabled: true })
                PredefinedSearch = search;
        }

        if (PredefinedSearch != null)
        {
            PageTitle = PredefinedSearch.Name;
            ObjectTypeName = PredefinedSearch.Name.ToLower();
        }

        if (PredefinedSearch == null || PredefinedSearch.IsDefaultForMetaverseObjectType)
        {
            _breadcrumbs = new List<BreadcrumbItem>
            {
                new("Home", href: "/", icon: Icons.Material.Filled.Home),
                new(MetaverseObjectType.PluralName, href: null, disabled: true)
            };
        }
        else
        {
            _breadcrumbs = new List<BreadcrumbItem>
            {
                new("Home", href: "/", icon: Icons.Material.Filled.Home),
                new(MetaverseObjectType.PluralName, href: $"/t/{MetaverseObjectType.PluralName.ToLower()}"),
                new(PredefinedSearch.Name, href: null, disabled: true)
            };
        }

        // Mark as initialised - now the table can render and load data
        _isInitialised = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!_preferencesLoaded)
        {
            try
            {
                var preferredSize = await PreferenceService.GetRowsPerPageAsync();
                _rowsPerPage = preferredSize;
                _dense = await PreferenceService.GetTableDenseAsync() == true;
                _preferencesLoaded = true;
                StateHasChanged(); // Re-render to show the table now that preference is loaded
            }
            catch
            {
                // JS interop not yet available, will retry on next render
            }
        }
    }

    private async Task OnRowsPerPageChanged(int newSize)
    {
        _rowsPerPage = newSize;
        await PreferenceService.SetRowsPerPageAsync(newSize);
    }

    private async Task<TableData<MetaverseObjectHeader>> ServerReload(TableState state, CancellationToken token)
    {
        if (PredefinedSearch == null)
        {
            return new TableData<MetaverseObjectHeader> { TotalItems = 0, Items = [] };
        }

        // A presence filter naming an attribute that does not exist cannot match any object; return an empty page
        // rather than falling through to an unfiltered query.
        if (_hasAttributeUnknown)
        {
            return new TableData<MetaverseObjectHeader> { TotalItems = 0, Items = [] };
        }

        _loading = true;
        StateHasChanged();

        try
        {
            // Convert MudBlazor's 0-indexed page to our 1-indexed page
            var page = state.Page + 1;
            var sortDescending = state.SortDirection == SortDirection.Descending;

            // Update URL with current page (without triggering navigation/reload)
            UpdateUrlWithPage(page);

            using var jim = JimFactory.Create();
            var result = await jim.Metaverse.GetMetaverseObjectHeadersPagedAsync(
                PredefinedSearch,
                page,
                state.PageSize,
                string.IsNullOrWhiteSpace(_searchString) ? null : _searchString,
                state.SortLabel,
                sortDescending,
                _hasAttributeId);

            return new TableData<MetaverseObjectHeader>
            {
                TotalItems = result.TotalResults,
                Items = result.Results
            };
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void UpdateUrlWithPage(int page)
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var baseUrl = uri.GetLeftPart(UriPartial.Path);

        // Preserve the attribute-presence filter and add ?p= only past page 1, so paging (and sharing a page-2 URL)
        // keeps the filter rather than silently dropping it.
        var queryParts = new List<string>();
        if (_hasAttributeName != null)
            queryParts.Add($"search={Utilities.HasAttributeSearchToken}{Uri.EscapeDataString(_hasAttributeName)}");
        if (page > 1)
            queryParts.Add($"p={page}");

        var newUrl = queryParts.Count > 0 ? $"{baseUrl}?{string.Join("&", queryParts)}" : baseUrl;

        // Update URL without navigation (replace current history entry)
        NavManager.NavigateTo(newUrl, replace: true);
    }

    private void OnSearch(string text)
    {
        _searchString = text;
        _table?.ReloadServerData();
    }

    private void ClearHasAttributeFilter()
    {
        _hasAttributeName = null;
        _hasAttributeId = null;
        _hasAttributeUnknown = false;

        // Drop the presence filter from the URL (keep the base path) without a full reload, then refresh the table.
        var baseUrl = NavManager.ToAbsoluteUri(NavManager.Uri).GetLeftPart(UriPartial.Path);
        NavManager.NavigateTo(baseUrl, replace: true);
        _table?.ReloadServerData();
    }

    private int GetPageFromUrl()
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        var pageStr = query["p"];
        if (int.TryParse(pageStr, out var page) && page > 0)
            return page;
        return 1; // Default to page 1
    }

    private string? GetSearchFromUrl()
    {
        var uri = NavManager.ToAbsoluteUri(NavManager.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        return query["search"];
    }

    private void HandleRowClick(TableRowClickEventArgs<MetaverseObjectHeader> args)
    {
        // Prevent navigation while data is loading to avoid concurrent EF operations
        if (_loading || args.Item == null)
            return;

        // Navigate using absolute path to ensure no query params are carried over
        var href = Utilities.GetMetaverseObjectHref(args.Item);
        var uri = NavManager.ToAbsoluteUri(href);
        NavManager.NavigateTo(uri.AbsolutePath);
    }
}
