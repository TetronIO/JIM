<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudText Typo="Typo.body2" Class="mud-text-secondary">@Setting?.Description</MudText>

            @if (Setting != null)
            {
                @switch (Setting.ValueType)
                {
                    case ServiceSettingValueType.Boolean:
                        <MudSwitch T="bool" @bind-Value="_boolValue" Color="Color.Primary" Label="@(_boolValue ? "Enabled" : "Disabled")" />
                        break;

                    case ServiceSettingValueType.Enum:
                        <MudSelect T="string" @bind-Value="_value" Label="Value" Variant="Variant.Outlined">
                            @foreach (var enumValue in GetEnumValues())
                            {
                                <MudSelectItem Value="@enumValue">@enumValue</MudSelectItem>
                            }
                        </MudSelect>
                        break;

                    case ServiceSettingValueType.Integer:
                        <MudNumericField T="int?" @bind-Value="_intValue" Label="Value" Variant="Variant.Outlined" />
                        break;

                    case ServiceSettingValueType.TimeSpan:
                        <MudTextField @bind-Value="_value" Label="Value (format: d.hh:mm:ss)" Variant="Variant.Outlined"
                            Immediate="true" Error="@(!IsTimeSpanValueValid())"
                            ErrorText="Enter a valid duration in the format d.hh:mm:ss"
                            HelperText="Example: 30.00:00:00 for 30 days" />
                        break;

                    case ServiceSettingValueType.StringEncrypted:
                        <MudTextField @bind-Value="_value" Label="Value" Variant="Variant.Outlined"
                            InputType="@(_showPassword ? InputType.Text : InputType.Password)"
                            Adornment="Adornment.End"
                            AdornmentIcon="@(_showPassword ? Icons.Material.Filled.VisibilityOff : Icons.Material.Filled.Visibility)"
                            AdornmentAriaLabel="Toggle password visibility"
                            OnAdornmentClick="@(() => _showPassword = !_showPassword)" />
                        break;

                    default:
                        <MudTextField @bind-Value="_value" Label="Value" Variant="Variant.Outlined" />
                        break;
                }

                @if (!string.IsNullOrEmpty(Setting.DefaultValue))
                {
                    <MudText Typo="Typo.caption" Class="mud-text-secondary">Default: @GetDefaultDisplayValue()</MudText>
                }
            }
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="Submit" Disabled="@(!CanSave())">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public ServiceSetting? Setting { get; set; }

    private string? _value;
    private int? _intValue;
    private bool _boolValue;
    private bool _showPassword;

    protected override void OnInitialized()
    {
        if (Setting != null)
        {
            _value = Setting.GetEffectiveValue();
            if (Setting.ValueType == ServiceSettingValueType.Integer && int.TryParse(_value, out var intVal))
            {
                _intValue = intVal;
            }
            if (Setting.ValueType == ServiceSettingValueType.Boolean)
            {
                _boolValue = string.Equals(_value, "true", StringComparison.OrdinalIgnoreCase);
            }
        }
    }

    private IEnumerable<string> GetEnumValues()
    {
        if (Setting?.EnumTypeName == null)
            return Enumerable.Empty<string>();

        // Handle known enum types
        if (Setting.EnumTypeName == typeof(PartitionValidationMode).FullName)
        {
            return Enum.GetNames<PartitionValidationMode>();
        }

        return Enumerable.Empty<string>();
    }

    private string GetDefaultDisplayValue()
    {
        if (Setting?.ValueType == ServiceSettingValueType.Boolean)
            return string.Equals(Setting.DefaultValue, "true", StringComparison.OrdinalIgnoreCase) ? "Enabled" : "Disabled";
        return Setting?.DefaultValue ?? string.Empty;
    }

    private bool IsTimeSpanValueValid() =>
        TimeSpan.TryParse(_value, System.Globalization.CultureInfo.InvariantCulture, out _);

    // Gates the Save button per the form action gating rules (src/JIM.Web/CLAUDE.md): a TimeSpan setting must
    // hold a parseable duration or downstream consumers fall back to defaults with the garbage stored, and an
    // Enum setting must have a selection. Booleans, integers (the numeric field enforces the type), and strings
    // (legitimately emptied to fall back to the default value) are always saveable.
    private bool CanSave()
    {
        return Setting?.ValueType switch
        {
            ServiceSettingValueType.TimeSpan => IsTimeSpanValueValid(),
            ServiceSettingValueType.Enum => !string.IsNullOrWhiteSpace(_value),
            _ => true
        };
    }

    private void Cancel() => MudDialog.Cancel();

    private void Submit()
    {
        var result = Setting?.ValueType switch
        {
            ServiceSettingValueType.Integer => _intValue?.ToString(),
            ServiceSettingValueType.Boolean => _boolValue.ToString().ToLowerInvariant(),
            _ => _value
        };
        MudDialog.Close(DialogResult.Ok(result));
    }
}
